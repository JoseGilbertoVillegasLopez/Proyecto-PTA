<turbo-frame id="content">
	<section class="proceso-clave-new-card">

		<header class="proceso-clave-new-header">

			<!-- VOLVER -->
			<a href="{{ path('app_proceso_clave_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="proceso-clave-new-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- TÍTULO -->
			<h1 class="proceso-clave-new-title">
				Crear nuevo proceso clave
			</h1>

			<!-- ESPACIADOR -->
			<div class="proceso-clave-new-header-spacer" aria-hidden="true"></div>

		</header>

		{{ form_start(form, {
			action: path('app_proceso_clave_new'),
			attr: {
				'data-turbo-frame': 'content',
				'class': 'proceso-clave-new-form'
			}
		}) }}

			<div class="proceso-clave-new-group">
				{{ form_label(form.nombre, null, {'label_attr': {'class': 'proceso-clave-new-label'}}) }}
				{{ form_widget(form.nombre, {'attr': {'class': 'proceso-clave-new-input'}}) }}
				{{ form_errors(form.nombre) }}
			</div>

			<div class="proceso-clave-new-group">
				{{ form_label(form.pei, null, {'label_attr': {'class': 'proceso-clave-new-label'}}) }}
				{{ form_widget(form.pei, {'attr': {'class': 'proceso-clave-new-input'}}) }}
				{{ form_errors(form.pei) }}
			</div>

			<div class="proceso-clave-new-group">
				{{ form_label(form.paig, null, {'label_attr': {'class': 'proceso-clave-new-label'}}) }}
				{{ form_widget(form.paig, {'attr': {'class': 'proceso-clave-new-input'}}) }}
				{{ form_errors(form.paig) }}
			</div>

			<div class="proceso-clave-new-group">
				{{ form_label(form.metaPdiPta, null, {'label_attr': {'class': 'proceso-clave-new-label'}}) }}
				{{ form_widget(form.metaPdiPta, {'attr': {'class': 'proceso-clave-new-input'}}) }}
				{{ form_errors(form.metaPdiPta) }}
			</div>

			<div class="proceso-clave-new-actions">
				<button type="submit" class="proceso-clave-new-submit-btn" title="Guardar">
					<i class="bi bi-check-lg"></i>
				</button>
			</div>

		{{ form_end(form) }}

	</section>
</turbo-frame>