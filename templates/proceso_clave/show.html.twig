<turbo-frame id="content">
	<section class="proceso-clave-show">

		<header class="proceso-clave-show__header">

			<a href="{{ path('app_proceso_clave_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="proceso-clave-show__icon-btn proceso-clave-show__icon-btn--back"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<h1 class="proceso-clave-show__title">
				Información del proceso clave
			</h1>

			<div class="proceso-clave-show__header-actions">
				<a href="{{ path('app_proceso_clave_edit', {'id': proceso.id}) }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="proceso-clave-show__icon-btn proceso-clave-show__icon-btn--edit"
				   title="Editar">
					<i class="bi bi-pencil"></i>
				</a>
			</div>

		</header>

		<table class="proceso-clave-show__table">
			<tbody>

				<tr>
					<th>Nombre</th>
					<td>{{ proceso.nombre }}</td>
				</tr>

				<tr>
					<th>PEI</th>
					<td>{{ proceso.pei }}</td>
				</tr>

				<tr>
					<th>PAIG</th>
					<td>{{ proceso.paig }}</td>
				</tr>

				<tr>
					<th>Meta PDI / PTA</th>
					<td>{{ proceso.metaPdiPta }}</td>
				</tr>

			</tbody>
		</table>

	</section>
</turbo-frame>