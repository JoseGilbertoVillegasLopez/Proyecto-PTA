<turbo-frame id="content">
	<section class="plantilla-indicadores-card" data-page="plantilla-indicadores-edit">
		<header class="plantilla-indicadores-header">
			<a href="{{ path('app_indicadores_basicos_plantilla_indicadores') }}" data-turbo-frame="content" data-turbo-action="replace" class="plantilla-indicadores-back-btn" title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<div class="plantilla-indicadores-header__center">
				<h4 class="plantilla-indicadores-title">
					<i class="bi bi-pencil-square"></i>
					Editar plantilla de indicadores
				</h4>
			</div>

			<div class="plantilla-indicadores-header__actions">
				<button type="submit" form="plantilla-indicadores-edit-form" class="plantilla-indicadores-save-btn plantilla-indicadores-save-btn--header" title="Guardar plantilla">
					<i class="bi bi-check2-circle"></i>
				</button>
			</div>
		</header>

		<form id="plantilla-indicadores-edit-form" method="post" action="{{ path('app_indicadores_basicos_plantilla_indicadores_edit') }}" data-turbo-frame="content" class="plantilla-indicadores-form">
			<input type="hidden" name="_token" value="{{ csrf_token('edit_plantilla_indicadores') }}">

			<div class="plantilla-indicadores-table-wrapper">
				<table class="plantilla-indicadores-table plantilla-indicadores-table--edit">
					<thead>
						<tr>
							<th colspan="9" class="plantilla-indicadores-institution">
								Instituto Tecnol&oacute;gico Superior de Cosamaloapan
							</th>
						</tr>
						<tr>
							<th class="plantilla-indicadores-col-indicador">Indicador</th>
							{% for ciclo in ciclos %}
								<th>Cantidad</th>
								<th>%Ciclo {{ ciclo.nombre }}</th>
							{% endfor %}
							<th>Media estatal</th>
							<th>Media nacional</th>
						</tr>
					</thead>
					<tbody>
						{% for grupo in grupos_indicadores %}
							<tr class="plantilla-indicadores-group-row">
								<td colspan="9">{{ grupo.nombre }}</td>
							</tr>

							{% for indicador in grupo.indicadores %}
								{% set indicadorValores = valores[indicador.id] ?? {} %}
								{% set indicadorMedia = medias[indicador.id] ?? null %}
								{% set indicadorCambios = recent_changes[indicador.id] ?? {} %}
								<tr class="plantilla-indicadores-data-row">
									<td rowspan="2" class="plantilla-indicadores-name">
										{{ indicador.nombreIndicador }}
									</td>
									{% for ciclo in ciclos %}
										{% set cicloValor = indicadorValores[ciclo.id] ?? null %}
										{% set cicloCambios = indicadorCambios[ciclo.id] ?? {} %}
										{% set cicloAbierto = ciclo.activo %}
										<td class="plantilla-indicadores-input-cell {{ cicloAbierto ? '' : 'plantilla-indicadores-input-cell--locked' }} {{ cicloCambios.cantidad1 is defined ? 'plantilla-indicadores-cell--recent' : '' }}">
											<input type="number" step="1" min="0" name="indicadores[{{ indicador.id }}][ciclos][{{ ciclo.id }}][cantidad1]" value="{{ cicloValor and cicloValor.cantidad1 is not null ? cicloValor.cantidad1|number_format(0, '.', '') : '' }}" class="plantilla-indicadores-input" data-live-ciclo-input data-track-modified data-original-value="{{ cicloValor and cicloValor.cantidad1 is not null ? cicloValor.cantidad1|number_format(0, '.', '') : '' }}" data-indicador-id="{{ indicador.id }}" data-ciclo="{{ ciclo.id }}" data-cantidad="1" {{ cicloAbierto ? '' : 'disabled' }} title="{{ cicloAbierto ? 'Ciclo abierto' : 'Ciclo cerrado' }}">
										</td>
										<td rowspan="2" class="plantilla-indicadores-value-cell plantilla-indicadores-result-cell {{ cicloCambios.resultado is defined ? 'plantilla-indicadores-cell--recent' : '' }}" data-live-ciclo-result data-original-result="{{ cicloValor and cicloValor.resultadoCiclo is not null ? cicloValor.resultadoCiclo ~ '%' : '' }}" data-indicador-id="{{ indicador.id }}" data-ciclo="{{ ciclo.id }}">
											{{ cicloValor and cicloValor.resultadoCiclo is not null ? cicloValor.resultadoCiclo ~ '%' : '' }}
										</td>
									{% endfor %}
									{% set mediaCambios = indicadorCambios.media ?? {} %}
									<td rowspan="2" class="plantilla-indicadores-input-cell plantilla-indicadores-media-cell {{ mediaCambios.estatal is defined ? 'plantilla-indicadores-cell--recent' : '' }}">
										<input type="number" step="0.01" min="0" name="indicadores[{{ indicador.id }}][media][estatal]" value="{{ indicadorMedia ? indicadorMedia.mediaEstatal : '' }}" class="plantilla-indicadores-input" data-track-modified data-original-value="{{ indicadorMedia ? indicadorMedia.mediaEstatal : '' }}">
									</td>
									<td rowspan="2" class="plantilla-indicadores-input-cell plantilla-indicadores-media-cell {{ mediaCambios.nacional is defined ? 'plantilla-indicadores-cell--recent' : '' }}">
										<input type="number" step="0.01" min="0" name="indicadores[{{ indicador.id }}][media][nacional]" value="{{ indicadorMedia ? indicadorMedia.mediaNacional : '' }}" class="plantilla-indicadores-input" data-track-modified data-original-value="{{ indicadorMedia ? indicadorMedia.mediaNacional : '' }}">
									</td>
								</tr>
								<tr class="plantilla-indicadores-data-row plantilla-indicadores-data-row--second">
									{% for ciclo in ciclos %}
										{% set cicloValor = indicadorValores[ciclo.id] ?? null %}
										{% set cicloCambios = indicadorCambios[ciclo.id] ?? {} %}
										{% set cicloAbierto = ciclo.activo %}
										<td class="plantilla-indicadores-input-cell {{ cicloAbierto ? '' : 'plantilla-indicadores-input-cell--locked' }} {{ cicloCambios.cantidad2 is defined ? 'plantilla-indicadores-cell--recent' : '' }}">
											<input type="number" step="1" min="0" name="indicadores[{{ indicador.id }}][ciclos][{{ ciclo.id }}][cantidad2]" value="{{ cicloValor and cicloValor.cantidad2 is not null ? cicloValor.cantidad2|number_format(0, '.', '') : '' }}" class="plantilla-indicadores-input" data-live-ciclo-input data-track-modified data-original-value="{{ cicloValor and cicloValor.cantidad2 is not null ? cicloValor.cantidad2|number_format(0, '.', '') : '' }}" data-indicador-id="{{ indicador.id }}" data-ciclo="{{ ciclo.id }}" data-cantidad="2" {{ cicloAbierto ? '' : 'disabled' }} title="{{ cicloAbierto ? 'Ciclo abierto' : 'Ciclo cerrado' }}">
										</td>
									{% endfor %}
								</tr>
							{% endfor %}
						{% else %}
							<tr>
								<td colspan="9" class="plantilla-indicadores-empty-message">
									No hay indicadores b&aacute;sicos activos para editar.
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

		</form>
	</section>
</turbo-frame>
