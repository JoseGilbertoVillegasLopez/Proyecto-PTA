<turbo-frame id="content">
	<section class="indicadores-basicos-show-card">

		<header
			class="indicadores-basicos-show-header">

			<!-- IZQUIERDA: VOLVER -->
			<a href="{{ path('app_indicadores_basicos_index') }}" data-turbo-frame="content" data-turbo-action="replace" class="indicadores-basicos-show-back-btn" title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- CENTRO: TÍTULO -->
			<h1 class="indicadores-basicos-show-title">
				Información del indicador básico
			</h1>


		</header>

		<div class="indicadores-basicos-show-table-wrapper">
			<table class="indicadores-basicos-show-table">
				<tbody>
					<tr>
						<th>Nombre del indicador</th>
						<td>{{ indicador.nombreIndicador }}</td>
					</tr>

					<tr>
						<th>Fórmula</th>
						<td>{{ indicador.formula }}</td>
					</tr>

					<tr>
						<th>Observaciones</th>
						<td>{{ indicador.observaciones ?: '—' }}</td>
					</tr>

					<tr>
						<th>Estado</th>
						<td>
							<span class="indicadores-basicos-show-status-badge {{ indicador.activo ? 'indicadores-basicos-show-status-badge--active' : 'indicadores-basicos-show-status-badge--inactive' }}">
								{{ indicador.activo ? 'Activo' : 'Inactivo' }}
							</span>
						</td>
					</tr>
				</tbody>
			</table>
		</div>

	</section>
</turbo-frame>
