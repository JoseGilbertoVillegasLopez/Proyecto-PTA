<turbo-frame id="content">
	<div class="card indicadores-basicos-index-card" data-page="indicadores-basicos-index">

		<h4 class="mb-3 indicadores-basicos-index-title">
			<i class="bi bi-bar-chart-line-fill"></i>
			Lista de indicadores básicos
		</h4>

		<div
			class="indicadores-basicos-index-toolbar">

			{# IZQUIERDA — BOTÓN AGREGAR #}
			<div class="indicadores-basicos-index-toolbar__left">
				{% if es_encargado_modulo('indicadores_basicos') %}
					<a href="{{ path('app_indicadores_basicos_new') }}" data-turbo-frame="content" data-turbo-action="advance" class="indicadores-basicos-index-add-btn">
						<i class="bi bi-plus-circle-fill"></i>
						<span>Crear indicador</span>
					</a>
				{% endif %}
				{% if es_encargado_modulo('reporte_indicadores') %}
					<a href="{{ path('app_reporte_indicadores_encargado_index') }}" data-turbo-frame="content" data-turbo-action="advance" class="indicadores-basicos-index-add-btn indicadores-basicos-index-add-btn--reports">
						<i class="bi bi-file-earmark-bar-graph"></i>
						<span>Reportes</span>
					</a>
				{% elseif tiene_acceso_modulo('reporte_indicadores') %}
					<a href="{{ path('app_reporte_indicadores_index') }}" data-turbo-frame="content" data-turbo-action="advance" class="indicadores-basicos-index-add-btn indicadores-basicos-index-add-btn--reports">
						<i class="bi bi-file-earmark-bar-graph"></i>
						<span>Reportes</span>
					</a>
				{% endif %}
				<a href="{{ path('app_indicadores_basicos_plantilla_indicadores') }}" data-turbo-frame="content" data-turbo-action="advance" class="indicadores-basicos-index-add-btn indicadores-basicos-index-add-btn--template">
					<i class="bi bi-table"></i>
					<span>Semáforo</span>
				</a>
			</div>

			{# DERECHA — BUSCADOR #}
			<div class="indicadores-basicos-index-toolbar__right">
				<div class="indicadores-basicos-index-search">
					<i class="bi bi-search"></i>
					<input type="text" id="indicadores-basicos-search" placeholder="Buscar indicador...">
				</div>
			</div>
		</div>

		<div class="indicadores-basicos-index-table-wrapper">
			<table class="indicadores-basicos-index-table">
				<thead>
					<tr>
						<th>Indicador</th>
						<th>Fórmula</th>
						<th>Observaciones</th>
						<th>Responsable</th>
						{% if is_granted('ROLE_ADMIN') %}
							<th class="text-center">Estado</th>
						{% endif %}
						<th class="text-center">Acciones</th>
					</tr>
				</thead>
				<tbody>
					{% for indicador in indicadores_basicos %}
						<tr class="indicadores-basicos-row">
							<td class="indicadores-basicos-nombre">
								{{ indicador.nombreIndicador }}
							</td>
							<td class="indicadores-basicos-formula">
								{{ indicador.formula }}
							</td>
							<td class="indicadores-basicos-observaciones">
								{{ indicador.observaciones ?: '—' }}
							</td>
							<td class="indicadores-basicos-responsable">
								{% if indicador.departamentos|length > 0 %}
									{% for dep in indicador.departamentos %}{{ dep.nombre }}{% if not loop.last %}, {% endif %}{% endfor %}
								{% else %}
									—
								{% endif %}
							</td>
							{% if is_granted('ROLE_ADMIN') %}
								<td class="text-center">
									<span class="indicadores-basicos-index-badge {{ indicador.isActivo() ? 'indicadores-basicos-index-badge--active' : 'indicadores-basicos-index-badge--inactive' }}">
										{{ indicador.isActivo() ? 'Activo' : 'Inactivo' }}
									</span>
								</td>
							{% endif %}
							<td class="text-center">
								<div class="indicadores-basicos-index-actions">
									<a href="{{ path('app_indicadores_basicos_show', {'id': indicador.id}) }}" data-turbo-frame="content" data-turbo-action="advance" class="indicadores-basicos-index-action-btn indicadores-basicos-index-action-btn--view" title="Ver indicador">
										<i class="bi bi-eye"></i>
									</a>

									{% if is_granted('ROLE_ADMIN') %}
										<a href="{{ path('app_indicadores_basicos_edit', {'id': indicador.id}) }}" data-turbo-frame="content" data-turbo-action="advance" class="indicadores-basicos-index-action-btn indicadores-basicos-index-action-btn--edit" title="Editar indicador">
											<i class="bi bi-pencil-square"></i>
										</a>
									{% endif %}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="{{ is_granted('ROLE_ADMIN') ? 6 : 5 }}" class="text-center text-muted indicadores-basicos-index-empty">
								No se encontraron indicadores básicos.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>
</turbo-frame>
