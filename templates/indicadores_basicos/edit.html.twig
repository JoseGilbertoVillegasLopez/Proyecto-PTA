<turbo-frame id="content">
	<section class="indicadores-basicos-edit-card">

		<header class="indicadores-basicos-edit-header">

			<!-- VOLVER -->
			<a href="{{ path('app_indicadores_basicos_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="indicadores-basicos-edit-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- TÍTULO + SUBTÍTULO -->
			<div class="indicadores-basicos-edit-header-center">
				<h1 class="indicadores-basicos-edit-title">
					Editar indicador: {{ indicador.nombreIndicador }}
				</h1>

				<p class="indicadores-basicos-edit-subtitle">
					Edita solo los campos necesarios
				</p>
			</div>

			<!-- ESPACIADOR -->
			<div class="indicadores-basicos-edit-header-spacer" aria-hidden="true"></div>

		</header>

		{{ form_start(form, {
            action: path('app_indicadores_basicos_edit', { id: indicador.id }),
            attr: {
                'data-turbo-frame': 'content',
                'class': 'indicadores-basicos-edit-form'
            }
        }) }}

			<div class="indicadores-basicos-edit-group">
				{{ form_label(form.nombreIndicador, null, {'label_attr': {'class': 'indicadores-basicos-edit-label'}}) }}
				{{ form_widget(form.nombreIndicador, {'attr': {'class': 'indicadores-basicos-edit-input'}}) }}
				{{ form_errors(form.nombreIndicador) }}
			</div>

			<div class="indicadores-basicos-edit-group">
				{{ form_label(form.formula, null, {'label_attr': {'class': 'indicadores-basicos-edit-label'}}) }}
				{{ form_widget(form.formula, {'attr': {'class': 'indicadores-basicos-edit-input'}}) }}
				{{ form_errors(form.formula) }}
			</div>

			<div class="indicadores-basicos-edit-group">
				{{ form_label(form.observaciones, null, {'label_attr': {'class': 'indicadores-basicos-edit-label'}}) }}
				{{ form_widget(form.observaciones, {'attr': {'class': 'indicadores-basicos-edit-textarea'}}) }}
				{{ form_errors(form.observaciones) }}
			</div>

			<div class="indicadores-basicos-edit-group">
				{{ form_label(form.activo, null, {'label_attr': {'class': 'indicadores-basicos-edit-label'}}) }}
				{{ form_widget(form.activo, {'attr': {'class': 'indicadores-basicos-edit-select'}}) }}
				{{ form_errors(form.activo) }}
			</div>

			<div class="indicadores-basicos-edit-actions">
				<button type="submit" class="indicadores-basicos-edit-save-btn" title="Guardar cambios">
					<i class="bi bi-check-lg"></i>
				</button>
			</div>

		{{ form_rest(form) }}
		{{ form_end(form) }}

	</section>
</turbo-frame>