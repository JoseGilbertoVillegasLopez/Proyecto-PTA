<turbo-frame id="content">
	<section class="partidas-presupuestales-show">

		<header class="partidas-presupuestales-show__header">

			<!-- IZQUIERDA: VOLVER -->
			<a href="{{ path('app_partidas_presupuestales_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="partidas-presupuestales-show__icon-btn partidas-presupuestales-show__icon-btn--back"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- CENTRO: TÍTULO -->
			<h1 class="partidas-presupuestales-show__title">
				Información de la partida presupuestal
			</h1>

			<!-- DERECHA: EDITAR -->
			<div class="partidas-presupuestales-show__header-actions">
				<a href="{{ path('app_partidas_presupuestales_edit', {'id': partida.id}) }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="partidas-presupuestales-show__icon-btn partidas-presupuestales-show__icon-btn--edit"
				   title="Editar">
					<i class="bi bi-pencil"></i>
				</a>
			</div>

		</header>

		<table class="partidas-presupuestales-show__table">
			<tbody>

				<tr>
					<th>Capítulo</th>
					<td>{{ partida.capitulo }}</td>
				</tr>

				<tr>
					<th>Partida</th>
					<td>{{ partida.partida }}</td>
				</tr>

				<tr>
					<th>Descripción</th>
					<td>{{ partida.descripcion }}</td>
				</tr>

			</tbody>
		</table>

	</section>
</turbo-frame>