<turbo-frame id="content">
	<section class="partidas-presupuestales-show-card">

		<header
			class="partidas-presupuestales-show-header">

			<!-- IZQUIERDA: VOLVER -->
			<a href="{{ path('app_partidas_presupuestales_index') }}" data-turbo-frame="content" data-turbo-action="replace" class="partidas-presupuestales-show-back-btn" title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- CENTRO: TÍTULO -->
			<h1 class="partidas-presupuestales-show-title">
				Información de la partida presupuestal
			</h1>


		</header>

		<div class="partidas-presupuestales-show-table-wrapper">
			<table class="partidas-presupuestales-show-table">
				<tbody>

					<tr>
						<th>Capítulo</th>
						<td>{{ partida.capitulo }}</td>
					</tr>

					<tr>
						<th>Partida</th>
						<td>{{ partida.partida }}</td>
					</tr>

					<tr>
						<th>Descripción</th>
						<td>{{ partida.descripcion }}</td>
					</tr>

					<tr>
						<th>Estado</th>
						<td>
							<span class="partidas-presupuestales-show-status-badge {{ partida.activo ? 'partidas-presupuestales-show-status-badge--active' : 'partidas-presupuestales-show-status-badge--inactive' }}">
								{{ partida.activo ? 'Activo' : 'Inactivo' }}
							</span>
						</td>
					</tr>

				</tbody>
			</table>
		</div>

	</section>
</turbo-frame>
