<turbo-frame id="content">
	<div class="card partidas-presupuestales-index-card" data-page="partidas-presupuestales-index">

		<h4 class="mb-3 partidas-presupuestales-index-title">
			<i class="bi bi-journal-text"></i>
			Lista de partidas presupuestales
		</h4>

		<div class="partidas-presupuestales-index-toolbar">

			{# IZQUIERDA — BOTÓN AGREGAR #}
			<div class="partidas-presupuestales-index-toolbar__left">
				<a href="{{ path('app_partidas_presupuestales_new') }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="partidas-presupuestales-index-add-btn">
					<i class="bi bi-plus-circle-fill"></i>
					<span>Crear nueva partida</span>
				</a>
			</div>

			{# DERECHA — BUSCADOR #}
			<div class="partidas-presupuestales-index-toolbar__right">
				<div class="partidas-presupuestales-index-search">
					<i class="bi bi-search"></i>
					<input type="text"
						   id="partidas-presupuestales-search"
						   placeholder="Buscar partida..."
						   autocomplete="off">
				</div>
			</div>
		</div>

		<div class="partidas-presupuestales-index-table-wrapper">
			<table class="partidas-presupuestales-index-table">
				<thead>
					<tr>
						<th>Capítulo</th>
						<th>Partida</th>
						<th>Descripción</th>
						<th class="text-center">Estado</th>
						<th class="text-center">Acciones</th>
					</tr>
				</thead>
				<tbody>
					{% for partida in partidas_presupuestales %}
						<tr class="partidas-presupuestales-row">
							<td class="partidas-presupuestales-capitulo">{{ partida.capitulo }}</td>
							<td class="partidas-presupuestales-partida">{{ partida.partida }}</td>
							<td class="partidas-presupuestales-descripcion">{{ partida.descripcion }}</td>
							<td class="text-center">
								<span class="partidas-presupuestales-index-badge {{ partida.activo ? 'partidas-presupuestales-index-badge--active' : 'partidas-presupuestales-index-badge--inactive' }}">
									{{ partida.activo ? 'Activo' : 'Inactivo' }}
								</span>
							</td>
							<td class="text-center">
								<div class="partidas-presupuestales-index-actions">
									<a href="{{ path('app_partidas_presupuestales_show', {'id': partida.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="partidas-presupuestales-index-action-btn partidas-presupuestales-index-action-btn--view"
									   title="Ver partida presupuestal">
										<i class="bi bi-eye"></i>
									</a>

									<a href="{{ path('app_partidas_presupuestales_edit', {'id': partida.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="partidas-presupuestales-index-action-btn partidas-presupuestales-index-action-btn--edit"
									   title="Editar partida presupuestal">
										<i class="bi bi-pencil-square"></i>
									</a>
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="text-center text-muted partidas-presupuestales-index-empty">
								No se encontraron partidas presupuestales.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>
</turbo-frame>