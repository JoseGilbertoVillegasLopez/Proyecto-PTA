<turbo-frame id="content">
	<section class="partidas-presupuestales-form partidas-presupuestales-form--new">

		<header class="partidas-presupuestales-form__header">

			<a href="{{ path('app_partidas_presupuestales_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="partidas-presupuestales-form__icon-btn partidas-presupuestales-form__icon-btn--back"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<h1 class="partidas-presupuestales-form__title">
				Crear nueva partida presupuestal
			</h1>

		</header>

		{{ form_start(form, {
			action: path('app_partidas_presupuestales_new'),
			attr: {
				'data-turbo-frame': 'content',
				'class': 'partidas-presupuestales-form__form'
			}
		}) }}

		<div class="partidas-presupuestales-form__group">
			{{ form_label(form.capitulo) }}
			{{ form_widget(form.capitulo) }}
			{{ form_errors(form.capitulo) }}
		</div>

		<div class="partidas-presupuestales-form__group">
			{{ form_label(form.partida) }}
			{{ form_widget(form.partida) }}
			{{ form_errors(form.partida) }}
		</div>

		<div class="partidas-presupuestales-form__group">
			{{ form_label(form.descripcion) }}
			{{ form_widget(form.descripcion) }}
			{{ form_errors(form.descripcion) }}
		</div>

		<div class="partidas-presupuestales-form__actions">
			<button type="submit"
			        class="partidas-presupuestales-form__submit partidas-presupuestales-form__submit--icon"
			        title="Guardar partida">
				<i class="bi bi-check-lg"></i>
			</button>
		</div>

		{{ form_end(form) }}

	</section>
</turbo-frame>