{% extends 'base.html.twig' %}

{% block title %}Iniciar sesión{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/login/login.css') }}">
{% endblock %}

{% block body %}
    <section class="login-wrapper">
         {# 🔴 JS INLINE — SE EJECUTA ANTES DEL PRIMER PAINT #}
        <script>
            (function () {
                const wrapper = document.currentScript.parentElement;
                const bubbleCount = 28;
                const height = window.innerHeight;

                for (let i = 0; i < bubbleCount; i++) {
                    const bubble = document.createElement('span');
                    bubble.className = 'login-bubble';

                    const size = Math.random() * 60 + 30;
                    bubble.style.width = size + 'px';
                    bubble.style.height = size + 'px';

                    bubble.style.top = (Math.random() * height) + 'px';
                    bubble.style.left = (Math.random() * 100) + '%';

                    const duration = 20 + Math.random() * 15;
                    bubble.style.animationDuration = duration + 's';
                    bubble.style.animationDelay = (-Math.random() * duration) + 's';

                    wrapper.appendChild(bubble);
                }
            })();
        </script>

        <div class="login-card">

            <form method="post" class="login-form" data-turbo="false">


                {% if error %}
                    <div class="alert alert-danger">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-3">
                        Ya iniciaste sesión como
                        <strong>{{ app.user.userIdentifier }}</strong>,
                        <a href="{{ path('app_logout') }}">Cerrar sesión</a>
                    </div>
                {% endif %}

                <h1 class="login-title">
                    Iniciar sesión
                </h1>

                <div class="login-field">
                    <label for="username">Usuario</label>
                    <input
                        type="text"
                        value="{{ last_username }}"
                        name="_username"
                        id="username"
                        class="form-control"
                        autocomplete="username"
                        required
                        autofocus
                    >
                </div>

                <div class="login-field">
                    <label for="password">Contraseña</label>
                    <input
                        type="password"
                        name="_password"
                        id="password"
                        class="form-control"
                        autocomplete="current-password"
                        required
                    >
                </div>

                <input
                    type="hidden"
                    name="_csrf_token"
                    data-controller="csrf-protection"
                    value="{{ csrf_token('authenticate') }}"
                >

                <div class="login-links">
                    <a href="{{ path('app_recuperar_password') }}">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>

                <button class="btn btn-lg btn-primary login-submit" type="submit">
                    Entrar
                </button>

            </form>

        </div>

    </section>
{% endblock %}

