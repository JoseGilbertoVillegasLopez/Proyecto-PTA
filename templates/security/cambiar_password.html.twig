{% extends 'base.html.twig' %}

{% block title %}Cambiar contraseña{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/cambiar_passaword/cambiar_passaword.css') }}">
{% endblock %}

{% block body %}
<section class="change-password-wrapper">
    {# 🔴 JS INLINE — ANTES DEL PRIMER PAINT #}
    <script>
        (function () {
            const wrapper = document.currentScript.parentElement;
            const bubbleCount = 28;
            const height = window.innerHeight;

            for (let i = 0; i < bubbleCount; i++) {
                const bubble = document.createElement('span');
                bubble.className = 'change-password-bubble';

                const size = Math.random() * 60 + 30;
                bubble.style.width = size + 'px';
                bubble.style.height = size + 'px';

                bubble.style.top = (Math.random() * height) + 'px';
                bubble.style.left = (Math.random() * 100) + '%';

                const duration = 20 + Math.random() * 15;
                bubble.style.animationDuration = duration + 's';
                bubble.style.animationDelay = (-Math.random() * duration) + 's';

                wrapper.appendChild(bubble);
            }
        })();
    </script>

    <div class="change-password-card">

        <h1 class="change-password-title">
            Bienvenido {{ personal.nombre }} {{ personal.apPaterno }}
        </h1>

        <p class="change-password-description">
            Es importante que usted actualice su contraseña con una que sea
            fácil de recordar para usted.
        </p>

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <form method="post" class="change-password-form">

            <div class="change-password-field">
                <label>Nueva contraseña</label>
                <input
                    type="password"
                    name="password"
                    class="form-control"
                    required
                >
            </div>

            <div class="change-password-field">
                <label>Confirmar contraseña</label>
                <input
                    type="password"
                    name="password_confirm"
                    class="form-control"
                    required
                >
            </div>

            <button class="btn btn-primary change-password-submit">
                Actualizar contraseña
            </button>

        </form>

    </div>

</section>
{% endblock %}

