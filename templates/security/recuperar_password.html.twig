{# 
=====================================================================
 VISTA: Recuperación de contraseña
 UBICACIÓN: templates/security/recuperar_password.html.twig
---------------------------------------------------------------------
 Esta vista muestra un formulario donde el usuario escribe:
   - Su correo registrado
   - Su puesto
   - Su departamento

El controlador valida esos datos y, si son correctos, llama al servicio
RecuperarPassword, que genera un password temporal, lo guarda,
y envía el correo al usuario.

La vista solo SE MUESTRA. No contiene lógica compleja.
=====================================================================
#}

{# Extendemos la plantilla base del proyecto (layout general) #}
{% extends 'base.html.twig' %}

{# Título que aparece en el <title> del navegador #}
{% block title %}Recuperar contraseña{% endblock %}

{# 
=====================================================================
 HOJA DE ESTILOS ESPECÍFICA
 Usa el mismo patrón visual que el login, pero con clases propias
=====================================================================
#}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/recuperar_password/recuperar_password.css') }}">
{% endblock %}

{% block body %}

{# 
=====================================================================
 CONTENEDOR PRINCIPAL (WRAPPER)
 - Fondo oscuro
 - Centrado total
 - Contenedor de burbujas animadas
=====================================================================
#}
<section class="recover-wrapper">

    {# 
    --------------------------------------------------------------
    JS INLINE — BURBUJAS FLOTANTES
    Se ejecuta antes del primer paint para evitar parpadeos
    --------------------------------------------------------------
    #}
    <script>
        (function () {
            const wrapper = document.currentScript.parentElement;
            const bubbleCount = 28;
            const height = window.innerHeight;

            for (let i = 0; i < bubbleCount; i++) {
                const bubble = document.createElement('span');
                bubble.className = 'recover-bubble';

                const size = Math.random() * 60 + 30;
                bubble.style.width = size + 'px';
                bubble.style.height = size + 'px';

                bubble.style.top = (Math.random() * height) + 'px';
                bubble.style.left = (Math.random() * 100) + '%';

                const duration = 20 + Math.random() * 15;
                bubble.style.animationDuration = duration + 's';
                bubble.style.animationDelay = (-Math.random() * duration) + 's';

                wrapper.appendChild(bubble);
            }
        })();
    </script>

    {# 
    --------------------------------------------------------------
    TARJETA DEL FORMULARIO
    - Sombra
    - Fondo oscuro
    - Bordes redondeados
    - Siempre encima de las burbujas
    --------------------------------------------------------------
    #}
    <div class="recover-card">

        {# Título principal de la vista #}
        <h1 class="recover-title">Recuperar contraseña</h1>

        {# Texto breve explicando qué debe hacer el usuario #}
        <p class="recover-description">
            Ingresa tus datos para validar tu identidad.
        </p>

        {# 
        --------------------------------------------------------------
        MENSAJE DE ERROR (SOLO SE MUESTRA SI EL CONTROLADOR LO ENVÍA)
        --------------------------------------------------------------
        #}
        {% if error %}
            <div class="alert alert-danger">
                {{ error }}
            </div>
        {% endif %}

        {# 
        --------------------------------------------------------------
        MENSAJE DE ÉXITO (SOLO SE MUESTRA SI EL CONTROLADOR LO ENVÍA)
        --------------------------------------------------------------
        #}
        {% if mensaje %}
            <div class="alert alert-success">
                {{ mensaje }}
            </div>
        {% endif %}

        {# 
        ==============================================================
        FORMULARIO DE RECUPERACIÓN
        - Método POST porque enviamos datos sensibles
        - NO usamos {{ form() }} para tener control absoluto del diseño
        - Turbo desactivado para evitar interferencias
        ==============================================================
        #}
        <form method="post" class="recover-form" data-turbo="false">

            {# 
            ----------------------------------------------------------
            CAMPO: CORREO
            Debe coincidir exactamente con Personal.correo
            ----------------------------------------------------------
            #}
            <div class="recover-field">
                <label>Correo electrónico</label>
                <input
                    type="email"
                    name="email"
                    class="form-control"
                    required
                    placeholder="ejemplo@correo.com"
                >
            </div>

            {# 
            ----------------------------------------------------------
            CAMPO: PUESTO
            - Select cargado desde BD
            - Solo puestos activos
            ----------------------------------------------------------
            #}
            <div class="recover-field">
                <label>Puesto</label>
                <select name="puesto" class="form-control" required>
                    <option value="">Selecciona tu puesto</option>
                    {% for puesto in puestos %}
                        <option value="{{ puesto.id }}">
                            {{ puesto.nombre }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# 
            ----------------------------------------------------------
            CAMPO: DEPARTAMENTO
            - Select cargado desde BD
            - Solo departamentos activos
            ----------------------------------------------------------
            #}
            <div class="recover-field">
                <label>Departamento</label>
                <select name="departamento" class="form-control" required>
                    <option value="">Selecciona tu departamento</option>
                    {% for depto in departamentos %}
                        <option value="{{ depto.id }}">
                            {{ depto.nombre }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# BOTÓN PARA ENVIAR EL FORMULARIO #}
            <button type="submit" class="btn btn-primary recover-submit">
                Recuperar contraseña
            </button>

            {# Enlace de retorno al login #}
            <a href="{{ path('app_login') }}" class="recover-back">
                Regresar al login
            </a>

        </form>
    </div>
</section>

{% endblock %}
