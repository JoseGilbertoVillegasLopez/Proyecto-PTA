<turbo-frame id="content">
<section class="ri-new" data-page="reporte-indicadores-new">

    {# ── HEADER ─────────────────────────────────────────────────────── #}
    <header class="ri-new__header">
        <a href="{{ path('app_reporte_indicadores_index') }}"
           data-turbo-frame="content" data-turbo-action="advance"
           class="ri-new__back" title="Volver">
            <i class="bi bi-arrow-left-short"></i>
            <span>Volver</span>
        </a>
        <h1 class="ri-new__title">Reportes trimestrales de indicadores básicos</h1>
        <div class="ri-new__header-spacer"></div>
    </header>

    {# ── VENTANAS DE ENTREGA ────────────────────────────────────────── #}
    <div class="ri-new__dates mb-5">
        <div class="ri-new__dates-inner">
            <div class="ri-new__dates-heading">
                <i class="bi bi-calendar3"></i>
                <span>Ventanas de entrega {{ datos.anio_actual }}</span>
            </div>
            <div class="ri-new__dates-pills">
                {% for item in datos.fechas_reporte %}
                    <div class="ri-new__pill">
                        <span class="ri-new__pill-period">{{ item.periodo }}</span>
                        <span class="ri-new__pill-sep">·</span>
                        <span class="ri-new__pill-date">{{ item.fecha }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ── GRID DE TRIMESTRES ─────────────────────────────────────────── #}
    <div class="ri-new__grid">
        {% for trimestre in datos.trimestres %}
            <article class="ri-new__card ri-new__card--{{ trimestre.estado_key }}"
                     data-trimestre="{{ trimestre.numero }}">

                {# watermark #}
                <span class="ri-new__watermark">T{{ trimestre.numero }}</span>

                {# header: número + estado #}
                <div class="ri-new__card-head">
                    <div>
                        <p class="ri-new__card-q">Trimestre {{ trimestre.numero }}</p>
                        <p class="ri-new__card-name">{{ trimestre.nombre }}</p>
                    </div>
                    <span class="ri-new__badge ri-new__badge--{{ trimestre.estado_key }}">
                        {{ trimestre.estado_label }}
                    </span>
                </div>

                {# filas de info #}
                <div class="ri-new__info-rows">
                    <div class="ri-new__info-row">
                        <span>Periodo</span>
                        <strong>{{ trimestre.periodo_label }}</strong>
                    </div>
                    <div class="ri-new__info-row">
                        <span>Ventana</span>
                        <strong>{{ trimestre.ventana_texto }}</strong>
                    </div>
                    {% if trimestre.creado_fecha %}
                        <div class="ri-new__info-row">
                            <span>Creado</span>
                            <strong>{{ trimestre.creado_fecha|date('d/m/Y') }}</strong>
                        </div>
                    {% endif %}
                    {% if trimestre.entregado_fecha %}
                        <div class="ri-new__info-row ri-new__info-row--entregado">
                            <span>Entregado</span>
                            <strong>{{ trimestre.entregado_fecha|date('d/m/Y') }}</strong>
                        </div>
                    {% endif %}
                </div>

                {# mensaje de estado #}
                <p class="ri-new__msg ri-new__msg--{{ trimestre.estado_key }}">
                    {{ trimestre.estado_mensaje }}
                </p>

                {# acciones — centradas #}
                <div class="ri-new__actions">
                    {% if trimestre.puede_abrir and trimestre.reporte_id %}
                        <a href="{{ path('app_reporte_indicadores_trimestre_show', { id: trimestre.reporte_id }) }}"
                           data-turbo-frame="content" data-turbo-action="advance"
                           class="ri-new__btn ri-new__btn--view">
                            <i class="bi bi-eye"></i> Ver
                        </a>
                        {% if trimestre.estado_key != 'entregado' %}
                            <a href="{{ path('app_reporte_indicadores_trimestre_edit', { id: trimestre.reporte_id }) }}"
                               data-turbo-frame="content" data-turbo-action="advance"
                               class="ri-new__btn ri-new__btn--edit">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>
                            <form method="post"
                                  action="{{ path('app_reporte_indicadores_trimestre_entregar', { id: trimestre.reporte_id }) }}"
                                  data-turbo-frame="content">
                                <input type="hidden" name="_token" value="{{ csrf_token('reporte_indicadores_entregar') }}">
                                <button type="submit" class="ri-new__btn ri-new__btn--deliver">
                                    <i class="bi bi-send-check"></i> Entregar
                                </button>
                            </form>
                        {% endif %}
                    {% elseif trimestre.puede_crear %}
                        <form method="post"
                              action="{{ path('app_reporte_indicadores_trimestre_crear', { trimestre: trimestre.numero }) }}"
                              data-turbo-frame="content">
                            <input type="hidden" name="_token" value="{{ csrf_token('reporte_indicadores_trimestre_crear') }}">
                            <input type="hidden" name="anio" value="{{ datos.anio_actual }}">
                            <button type="submit" class="ri-new__btn ri-new__btn--create">
                                <i class="bi bi-plus-circle"></i> Crear reporte
                            </button>
                        </form>
                    {% else %}
                        <span class="ri-new__no-action">Sin acciones disponibles</span>
                    {% endif %}
                </div>

            </article>
        {% endfor %}
    </div>

</section>
</turbo-frame>
