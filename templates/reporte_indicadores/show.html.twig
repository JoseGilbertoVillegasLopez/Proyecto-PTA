<turbo-frame id="content">
	<section class="reporte-indicadores-show" data-page="reporte-indicadores-show">
		<header class="reporte-indicadores-show__header">
			<a href="{{ path('app_reporte_indicadores_new', { anio: reporte.anio }) }}" data-turbo-frame="content" data-turbo-action="advance" class="reporte-indicadores-show__back-btn" title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<h1 class="reporte-indicadores-show__title">
				<i class="bi bi-file-earmark-bar-graph"></i>
				Reporte {{ reporte.anio }} - Trimestre {{ reporte.trimestre }}
			</h1>

			<div class="reporte-indicadores-show__header-spacer"></div>
		</header>

		<div class="reporte-indicadores-show__summary">
			<article class="reporte-indicadores-show__summary-item">
				<span>Estado</span>
				<strong>{{ reporte.estado|capitalize }}</strong>
			</article>
			<article class="reporte-indicadores-show__summary-item">
				<span>Creado</span>
				<strong>{{ reporte.creadoFecha ? reporte.creadoFecha|date('d/m/Y') : 'Pendiente' }}</strong>
			</article>
			<article class="reporte-indicadores-show__summary-item">
				<span>Entregado</span>
				<strong>{{ reporte.entregadoFecha ? reporte.entregadoFecha|date('d/m/Y') : 'Sin entregar' }}</strong>
			</article>
		</div>

		<div class="reporte-indicadores-show__activities">
			{% for actividad in actividades %}
				<article class="reporte-indicadores-show__activity-card">
					<div class="reporte-indicadores-show__activity-label">Accion/Actividad {{ loop.index }}</div>

					<div class="reporte-indicadores-show__field">
						<span>Actividad</span>
						<strong>{{ actividad.accion }}</strong>
					</div>

					<div class="reporte-indicadores-show__field">
						<span>Indicador que impacta</span>
						<strong>{{ actividad.indicadorBasico.nombreIndicador }}</strong>
					</div>

					<div class="reporte-indicadores-show__field">
						<span>Descripcion</span>
						<p>{{ actividad.descripcion }}</p>
					</div>

					<div class="reporte-indicadores-show__evidences">
						{% for evidencia in actividad.evidencias %}
							<div class="reporte-indicadores-show__evidence-item">
								{% if evidencia.mimeType starts with 'image/' %}
									<img src="{{ evidencia.ruta }}" alt="{{ evidencia.archivoNombreOriginal }}">
								{% else %}
									<iframe src="{{ evidencia.ruta }}#toolbar=0&navpanes=0" title="{{ evidencia.archivoNombreOriginal }}"></iframe>
								{% endif %}
								<div class="reporte-indicadores-show__evidence-footer">
									<span>{{ evidencia.archivoNombreOriginal }}</span>
									<a href="{{ evidencia.ruta }}" download="{{ evidencia.archivoNombreOriginal }}" class="reporte-indicadores-show__download-btn" title="Descargar evidencia">
										<i class="bi bi-download"></i>
									</a>
								</div>
							</div>
						{% else %}
							<div class="reporte-indicadores-show__empty-evidence">Sin evidencias.</div>
						{% endfor %}
					</div>
				</article>
			{% else %}
				<div class="reporte-indicadores-show__empty-evidence">No hay actividades guardadas.</div>
			{% endfor %}
		</div>
	</section>
</turbo-frame>
