<turbo-frame id="content">
	<section class="personal-show-card">

		<header class="personal-show-header">

			<!-- IZQUIERDA: VOLVER -->
			<a href="{{ path('app_personal_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="personal-show-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- CENTRO: TÍTULO -->
			<h1 class="personal-show-title">
				Información del personal
			</h1>

			<!-- DERECHA: EDITAR -->
			<div class="personal-show-header-actions">
				<a href="{{ path('app_personal_edit', {'id': personal.id}) }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="personal-show-edit-btn"
				   title="Editar">
					<i class="bi bi-pencil"></i>
				</a>
			</div>

		</header>

		<div class="personal-show-details">
			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Nombre</span>
				<span class="personal-show-detail-value">{{ personal.nombre }}</span>
			</div>

			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Apellido paterno</span>
				<span class="personal-show-detail-value">{{ personal.apPaterno }}</span>
			</div>

			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Apellido materno</span>
				<span class="personal-show-detail-value">{{ personal.apMaterno }}</span>
			</div>

			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Correo</span>
				<span class="personal-show-detail-value">{{ personal.correo }}</span>
			</div>

			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Puesto</span>
				<span class="personal-show-detail-value">{{ personal.puesto.nombre }}</span>
			</div>

			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Departamento</span>
				<span class="personal-show-detail-value">{{ personal.departamento.nombre }}</span>
			</div>

			<div class="personal-show-detail">
				<span class="personal-show-detail-label">Estado</span>
				<span class="personal-show-detail-value">
					<span class="personal-show-status-badge {{ personal.activo ? 'personal-show-status-badge--active' : 'personal-show-status-badge--inactive' }}">
						{{ personal.activo ? 'Activo' : 'Inactivo' }}
					</span>
				</span>
			</div>
		</div>

		<section class="personal-nombramientos-card personal-show-nombramientos-card">

			<div class="personal-nombramientos-header">

				<h2 class="personal-nombramientos-title">
					Dictámenes activos
				</h2>

				<a href="{{ path('app_nombramiento_historial_personal', { id: personal.id, origen: 'show' }) }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="personal-nombramientos-history-btn">
					<i class="bi bi-clock-history"></i>
					Ver historial
				</a>

			</div>

			{% set nombramientosActivos = personal.nombramientos|filter(n => n.activo) %}

			{% if nombramientosActivos|length > 0 %}

				<div class="personal-nombramientos-list">

					{% for nombramiento in nombramientosActivos %}

						{% set nombramientoUrl = asset('uploads/nombramientos/' ~ nombramiento.archivo) %}

						<div class="personal-nombramiento-item">

							<button type="button"
									class="personal-nombramiento-preview-btn personal-show-nombramiento-preview-btn"
									data-pdf-url="{{ nombramientoUrl }}"
									data-pdf-name="{{ nombramiento.nombreOriginal }}"
									data-pdf-tipo="{{ nombramiento.tipo }}"
									data-pdf-fecha="{{ nombramiento.fechaSubida|date('d/m/Y') }}"
									aria-label="Ver dictamen {{ nombramiento.nombreOriginal }}">

								<iframe src="{{ nombramientoUrl }}#page=1&toolbar=0&navpanes=0&scrollbar=0&view=FitH"
										class="personal-nombramiento-preview-frame"
										title="Vista previa de {{ nombramiento.nombreOriginal }}"
										tabindex="-1"
										loading="lazy"></iframe>

							</button>

							<div class="personal-nombramiento-details">

								<p class="personal-nombramiento-name">
									{{ nombramiento.nombreOriginal }}
								</p>

								<small class="personal-nombramiento-meta">
									Tipo:
									{{ nombramiento.tipo }}
									<br>
									Subido:
									{{ nombramiento.fechaSubida|date('d/m/Y') }}
								</small>

							</div>

						</div>

					{% endfor %}

				</div>

			{% else %}

				<div class="personal-nombramiento-empty">
					<p class="personal-nombramiento-empty-text">
						No hay nombramientos activos.
					</p>
				</div>

			{% endif %}

		</section>

	</section>

	<div class="personal-nombramiento-pdf-preview-modal personal-nombramiento-pdf-preview-modal-hidden"
		 role="dialog"
		 aria-modal="true"
		 aria-labelledby="personal-nombramiento-pdf-preview-title"
		 hidden>
		<div class="personal-nombramiento-pdf-preview-modal-box">

			<div class="personal-nombramiento-pdf-preview-modal-header">
				<h3 id="personal-nombramiento-pdf-preview-title"
					class="personal-nombramiento-pdf-preview-modal-title"></h3>

				<button type="button"
						class="personal-nombramiento-pdf-preview-modal-close-btn"
						aria-label="Cerrar vista previa">
					<i class="bi bi-x-lg"></i>
				</button>
			</div>

			<iframe class="personal-nombramiento-pdf-preview-modal-frame"
					title="Vista previa del dictamen"></iframe>

			<div class="personal-nombramiento-pdf-preview-modal-meta">
				<p>
					<strong>Tipo:</strong>
					<span data-pdf-preview-tipo></span>
				</p>
				<p>
					<strong>Subido:</strong>
					<span data-pdf-preview-fecha></span>
				</p>
			</div>

		</div>
	</div>
</turbo-frame>
