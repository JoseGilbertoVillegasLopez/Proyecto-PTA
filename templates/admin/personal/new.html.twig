<turbo-frame id="content">
	<section class="personal-new-card">

		<header class="personal-new-header">

			<!-- VOLVER -->
			<a href="{{ path('app_personal_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="personal-new-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- TÍTULO -->
			<h1 class="personal-new-title">
				Crear nuevo personal
			</h1>

			<!-- ESPACIADOR -->
			<div class="personal-new-header-spacer" aria-hidden="true"></div>

		</header>

		{{ form_start(form, {
            action: path('app_personal_new'),
            attr: {
                'data-turbo-frame': 'content',
                'class': 'personal-new-form'
            }
        }) }}

			<div class="personal-new-group">
				{{ form_label(form.nombre, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.nombre, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.nombre) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.ap_paterno, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.ap_paterno, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.ap_paterno) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.ap_materno, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.ap_materno, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.ap_materno) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.correo, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.correo, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.correo) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.puesto, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.puesto, {'attr': {'class': 'personal-new-select'}}) }}
				{{ form_errors(form.puesto) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.departamento, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.departamento, {'attr': {'class': 'personal-new-select'}}) }}
				{{ form_errors(form.departamento) }}
			</div>

			<div class="personal-new-actions">
				<button type="submit" class="personal-new-submit-btn" title="Guardar">
					<i class="bi bi-check-lg"></i>
				</button>
			</div>

		{{ form_end(form) }}

	</section>
</turbo-frame>