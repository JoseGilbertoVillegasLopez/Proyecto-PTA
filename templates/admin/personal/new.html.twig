<turbo-frame id="content">
	<section class="personal-new-card">

		<header class="personal-new-header">

			<!-- VOLVER -->
			<a href="{{ path('app_personal_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="personal-new-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- TÍTULO -->
			<h1 class="personal-new-title">
				Crear nuevo personal
			</h1>

			<!-- ESPACIADOR -->
			<div class="personal-new-header-spacer" aria-hidden="true"></div>

		</header>

		{{ form_start(form, {
			action: path('app_personal_new'),
			attr: {
				'data-turbo-frame': 'content',
				'class': 'personal-new-form',
				'enctype': 'multipart/form-data'
			}
		}) }}

			<div class="personal-new-group">
				{{ form_label(form.nombre, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.nombre, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.nombre) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.ap_paterno, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.ap_paterno, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.ap_paterno) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.ap_materno, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.ap_materno, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.ap_materno) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.correo, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.correo, {'attr': {'class': 'personal-new-input'}}) }}
				{{ form_errors(form.correo) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.puesto, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.puesto, {'attr': {'class': 'personal-new-select'}}) }}
				{{ form_errors(form.puesto) }}
			</div>

			<div class="personal-new-group">
				{{ form_label(form.departamento, null, {'label_attr': {'class': 'personal-new-label'}}) }}
				{{ form_widget(form.departamento, {'attr': {'class': 'personal-new-select'}}) }}
				{{ form_errors(form.departamento) }}
			</div>

			<div class="personal-new-group personal-new-nombramiento-pdf-validation-group">

				{{ form_label(form.nombramiento_pdf, null, {
					'label_attr': {
						'class': 'personal-new-label'
					}
				}) }}

				{{ form_widget(form.nombramiento_pdf, {
					'attr': {
						'class': 'personal-new-input-file'
					}
				}) }}

				<div class="personal-new-error">
					{{ form_errors(form.nombramiento_pdf) }}
				</div>

				<p class="personal-new-nombramiento-client-error personal-new-nombramiento-client-error-hidden"
				   data-new-error-for="pdf"
				   aria-live="polite"
				   hidden>
					Debes agregar un archivo PDF.
				</p>

			</div>


			<div class="personal-new-group personal-new-nombramiento-tipo-validation-group">

				{{ form_label(form.nombramiento_tipo, null, {
					'label_attr': {
						'class': 'personal-new-label'
					}
				}) }}

				{{ form_widget(form.nombramiento_tipo, {
					'attr': {
						'class': 'personal-new-select'
					}
				}) }}

				<div class="personal-new-error">
					{{ form_errors(form.nombramiento_tipo) }}
				</div>

				<p class="personal-new-nombramiento-client-error personal-new-nombramiento-client-error-hidden"
				   data-new-error-for="tipo"
				   aria-live="polite"
				   hidden>
					Debes elegir un tipo de nombramiento.
				</p>

			</div>

			<div class="personal-new-actions">
				<button type="submit" class="personal-new-submit-btn" title="Guardar">
					<i class="bi bi-check-lg"></i>
				</button>
			</div>

		{{ form_end(form) }}

	</section>

	<div class="personal-new-nombramiento-validation-modal personal-new-nombramiento-validation-modal-hidden"
		 role="dialog"
		 aria-modal="true"
		 aria-labelledby="personal-new-nombramiento-validation-title"
		 aria-describedby="personal-new-nombramiento-validation-message"
		 hidden>
		<div class="personal-new-nombramiento-validation-modal-box">

			<div class="personal-new-nombramiento-validation-modal-icon">
				<i class="bi bi-exclamation-triangle-fill"></i>
			</div>

			<h3 id="personal-new-nombramiento-validation-title"
				class="personal-new-nombramiento-validation-modal-title">
				Faltan datos del nombramiento
			</h3>

			<p id="personal-new-nombramiento-validation-message"
			   class="personal-new-nombramiento-validation-modal-message"></p>

			<button type="button"
					class="personal-new-nombramiento-validation-modal-close-btn">
				Entendido
			</button>

		</div>
	</div>
</turbo-frame>
