<turbo-frame id="content">
	<div class="card personal-index-card" data-page="personal-index">

		<h4 class="mb-3 personal-index-title">
			<i class="bi bi-people-fill"></i>
			Lista de personal
		</h4>

		<div class="personal-index-toolbar">

			{# IZQUIERDA — BOTÓN AGREGAR #}
			<div class="personal-index-toolbar__left">
				<a href="{{ path('app_personal_new') }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="personal-index-add-btn">
					<i class="bi bi-person-plus-fill"></i>
					<span>Crear nuevo</span>
				</a>
			</div>

			{# DERECHA — BUSCADOR #}
			<div class="personal-index-toolbar__right">
				<div class="personal-index-search">
					<i class="bi bi-search"></i>
					<input type="text"
						   id="personal-search"
						   placeholder="Buscar personal..."
						   autocomplete="off">
				</div>
			</div>
		</div>

		<div class="personal-index-table-wrapper">
			<table class="personal-index-table">
				<thead>
					<tr>
						<th>Nombre completo</th>
						<th>Correo</th>
						<th>Puesto</th>
						<th>Departamento</th>
						<th class="text-center">Estado</th>
						<th class="text-center">Acciones</th>
					</tr>
				</thead>
				<tbody>
					{% for personal in personals %}
						<tr class="personal-row">
							<td class="personal-nombre">{{ personal }}</td>
							<td>{{ personal.correo }}</td>
							<td>{{ personal.puesto.nombre }}</td>
							<td>{{ personal.departamento.nombre }}</td>
							<td class="text-center">
								<span class="personal-index-badge {{ personal.activo ? 'personal-index-badge--active' : 'personal-index-badge--inactive' }}">
									{{ personal.activo ? 'Activo' : 'Inactivo' }}
								</span>
							</td>
							<td class="text-center">
								<div class="personal-index-actions">
									<a href="{{ path('app_personal_show', {'id': personal.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="personal-index-action-btn personal-index-action-btn--view"
									   title="Ver personal">
										<i class="bi bi-eye"></i>
									</a>

									<a href="{{ path('app_personal_edit', {'id': personal.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="personal-index-action-btn personal-index-action-btn--edit"
									   title="Editar personal">
										<i class="bi bi-pencil-square"></i>
									</a>
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="6" class="text-center text-muted personal-index-empty">
								No se encontraron registros.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>
</turbo-frame>