<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8">
		<title>Aviso administrativo</title>
	</head>
	<body style="margin:0;padding:0;background:#f4f6f9;font-family:Arial,Helvetica,sans-serif;">

		<div
			style="max-width:720px;margin:0 auto;background:#ffffff;">

			<!-- HEADER -->
			<div style="background:#0d6efd;color:#fff;padding:16px 24px;">
				<h2 style="margin:0;font-size:18px;">
					Aviso administrativo — Responsable
				</h2>
				<p style="margin:4px 0 0;font-size:13px;opacity:.9;">
					Periodo cerrado:
					{{ mesNombre }}
					{{ anio }}
				</p>
			</div>

			<!-- BODY -->
			<div style="padding:24px;color:#333;">

				<p>Estimado(a)
					<strong>{{ responsable }}</strong>,</p>

				<p>
					El periodo para registrar avances correspondiente a
					<strong>{{ mesNombre }}
						{{ anio }}</strong>
					ha concluido. Los siguientes PTA a su cargo presentan acciones sin avance.
				</p>

				{% for item in items %}
					<!-- PTA CARD -->
					<div style="border:1px solid #dee2e6;border-radius:6px;margin:20px 0;">

						<div style="background:#f1f5fb;padding:12px 16px;">
							<strong>PTA #{{ item.pta.id }}
								—
								{{ item.pta.nombre }}</strong><br>
							<span style="font-size:13px;color:#555;">
								{{ item.pta.objetivo }}
							</span>
						</div>

						<div style="padding:16px;">

							{% set indicadores = {} %}
							{% for a in item.acciones %}
								{% set indicadores = indicadores|merge({
                            (a.indiceIndicador): (indicadores[a.indiceIndicador]|default([]))|merge([a])
                        }) %}
							{% endfor %}

							{% for indice, acciones in indicadores %}
								<div style="margin-bottom:14px;">
									<div style="font-weight:bold;color:#0d6efd;margin-bottom:6px;">
										Indicador
										{{ indice + 1 }}:
										{{ acciones[0].indicadorNombre }}
									</div>
									<ul style="margin:0;padding-left:18px;">
										{% for acc in acciones %}
											<li style="margin-bottom:6px;">
												{{ acc.texto }}
											</li>
										{% endfor %}
									</ul>
								</div>
							{% endfor %}

						</div>
					</div>
				{% endfor %}

				<p style="margin-top:30px;font-size:13px;color:#555;">
					Le solicitamos conservar la documentación y justificación correspondiente
																				            para el seguimiento administrativo.
				</p>

				<p style="font-size:13px;">
					Atentamente,<br>
					<strong>{{ appName }}</strong>
				</p>

			</div>
		</div>

	</body>
</html>
