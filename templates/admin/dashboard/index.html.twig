{% extends 'base.html.twig' %}

{% block title %}Dashboard
{% endblock %}

{% block body %}
	<script>
		document.addEventListener("turbo:render", function () {
if (typeof Sfjs !== "undefined") {
Sfjs.loadToolbar();
}
});
	</script>

	<div
		style="display: flex; height: 94.8vh; background: #1e242b;">

		<!-- ASIDE -->
		<aside
			class="pta-dashboard-aside">

			<!-- BLOQUE CENTRADO -->
			<div
				class="pta-dashboard-menu-wrapper">

				<!-- HEADER -->
				<div class="pta-dashboard-header">
					<i class="bi bi-speedometer2 pta-dashboard-icon"></i>
					<h2 class="pta-dashboard-title">Menú</h2>
				</div>

				<!-- MENU -->
				<ul class="pta-dashboard-menu">

					<li class="pta-dashboard-menu-item">
						<a href="{{ path('app_personal_index') }}" data-turbo-frame="content" class="pta-dashboard-link">
							Personal
						</a>
					</li>

					<li class="pta-dashboard-menu-item">
						<a href="{{ path('app_departamento_index') }}" data-turbo-frame="content" class="pta-dashboard-link">
							Departamentos
						</a>
					</li>

					<li class="pta-dashboard-menu-item">
						<a href="{{ path('app_puesto_index') }}" data-turbo-frame="content" class="pta-dashboard-link">
							Puestos
						</a>
					</li>

					<li class="pta-dashboard-menu-item">
						<a href="{{ path('app_encabezado_index') }}" data-turbo-frame="content" class="pta-dashboard-link">
							PTA
						</a>
					</li>

				</ul>
			</div>

			<!-- LOGOUT -->
			<a href="{{ path('app_logout') }}" class="pta-dashboard-logout" title="Cerrar sesión">
				<i class="bi bi-door-open-fill"></i>
				Salir
			</a>

		</aside>

		<!-- CONTENIDO -->
		<main style="flex: 1; padding: 30px; overflow-y: auto;">
			<turbo-frame id="content" src="{{ path('app_personal_index') }}"></turbo-frame>
		</main>

	</div>
{% endblock %}
