<turbo-frame id="content">
	<section class="puesto-show-page-card">

		<header class="puesto-show-page-header">

			<!-- IZQUIERDA: VOLVER -->
			<a href="{{ path('app_puesto_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="puesto-show-page-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- CENTRO: TÍTULO -->
			<h1 class="puesto-show-page-title">
				Información del puesto
			</h1>

			<!-- DERECHA: EDITAR -->
			<div class="puesto-show-page-header-actions">
				<a href="{{ path('app_puesto_edit', {'id': puesto.id}) }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="puesto-show-page-edit-btn"
				   title="Editar">
					<i class="bi bi-pencil"></i>
				</a>
			</div>

		</header>

		<div class="puesto-show-page-table-wrapper">
			<table class="puesto-show-page-table">
				<tbody>

					<tr>
						<th>ID</th>
						<td>{{ puesto.id }}</td>
					</tr>

					<tr>
						<th>Nombre</th>
						<td>{{ puesto.nombre }}</td>
					</tr>

					<tr>
						<th>Supervisor directo</th>
						<td>
							{{ puesto.supervisorDirecto ? puesto.supervisorDirecto.nombre : '—' }}
						</td>
					</tr>

					<tr>
						<th>Estado</th>
						<td>
							<span class="puesto-show-page-status-badge {{ puesto.activo ? 'puesto-show-page-status-badge--active' : 'puesto-show-page-status-badge--inactive' }}">
								{{ puesto.activo ? 'Activo' : 'Inactivo' }}
							</span>
						</td>
					</tr>

				</tbody>
			</table>
		</div>

	</section>
</turbo-frame>