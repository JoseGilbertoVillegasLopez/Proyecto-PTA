<turbo-frame id="content">
	<section class="puesto-index-page-card" data-page="puesto-index">

		<h4 class="puesto-index-page-title">
			<i class="bi bi-briefcase-fill"></i>
			Lista de puestos
		</h4>

		<div class="puesto-index-page-toolbar">

			<div class="puesto-index-page-toolbar-left">
				<a href="{{ path('app_puesto_new') }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="puesto-index-page-add-btn">
					<i class="bi bi-briefcase-fill"></i>
					<span>Crear nuevo</span>
				</a>
			</div>

			<div class="puesto-index-page-toolbar-right">
				<div class="puesto-index-page-search">
					<i class="bi bi-search"></i>
					<input type="text"
						   id="puesto-search"
						   placeholder="Buscar puesto...">
				</div>
			</div>

		</div>

		<div class="puesto-index-page-table-wrapper">
			<table class="puesto-index-page-table">
				<thead>
					<tr>
						<th>Nombre</th>
						<th>Supervisor directo</th>
						<th>Estado</th>
						<th>Acciones</th>
					</tr>
				</thead>

				<tbody>
					{% for puesto in puestos %}
						<tr class="puesto-index-page-row">
							<td class="puesto-index-page-name">
								{{ puesto.nombre }}
							</td>

							<td class="puesto-index-page-supervisor">
								{{ puesto.supervisorDirecto ? puesto.supervisorDirecto.nombre : '—' }}
							</td>

							<td class="text-center">
								<span class="puesto-index-page-badge {{ puesto.activo ? 'puesto-index-page-badge--active' : 'puesto-index-page-badge--inactive' }}">
									{{ puesto.activo ? 'Activo' : 'Inactivo' }}
								</span>
							</td>

							<td class="text-center">
								<div class="puesto-index-page-actions">
									<a href="{{ path('app_puesto_show', {'id': puesto.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="puesto-index-page-action-btn puesto-index-page-action-btn--view"
									   title="Ver puesto">
										<i class="bi bi-eye"></i>
									</a>

									<a href="{{ path('app_puesto_edit', {'id': puesto.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="puesto-index-page-action-btn puesto-index-page-action-btn--edit"
									   title="Editar puesto">
										<i class="bi bi-pencil-square"></i>
									</a>
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4" class="puesto-index-page-empty">
								No se encontraron registros.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</section>
</turbo-frame>