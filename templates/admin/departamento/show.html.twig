<turbo-frame id="content">
	<section
		class="departamento-show">

		<!-- ===============================
						             HEADER
						        ================================ -->
		<header
			class="departamento-show__header">

			<!-- IZQUIERDA: VOLVER -->
			<a href="{{ path('app_departamento_index') }}" data-turbo-frame="content" data-turbo-action="replace" class="departamento-show__icon-btn departamento-show__icon-btn--back" title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<!-- CENTRO: TÍTULO -->
			<h1 class="departamento-show__title">
				Información del departamento
			</h1>

			<!-- DERECHA: EDITAR -->
			<div class="departamento-show__header-actions">
				<a href="{{ path('app_departamento_edit', {'id': departamento.id}) }}" data-turbo-frame="content" data-turbo-action="advance" class="departamento-show__icon-btn departamento-show__icon-btn--edit" title="Editar">
					<i class="bi bi-pencil"></i>
				</a>
			</div>

		</header>

		<!-- ===============================
						             TABLE
						        ================================ -->
		<table class="departamento-show__table">
			<tbody>

				<tr>
					<th>ID</th>
					<td>{{ departamento.id }}</td>
				</tr>

				<tr>
					<th>Nombre</th>
					<td>{{ departamento.nombre }}</td>
				</tr>

			</tbody>
		</table>

	</section>
</turbo-frame>
