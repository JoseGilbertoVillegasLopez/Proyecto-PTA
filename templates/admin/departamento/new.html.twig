<turbo-frame id="content">
	<section class="departamento-new-page-card">

		<header class="departamento-new-page-header">
			<a href="{{ path('app_departamento_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="departamento-new-page-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>
			<div class="departamento-new-page-header-center">
				<h1 class="departamento-new-page-title">
					<i class="bi bi-buildings-fill"></i>
					Nuevo departamento
				</h1>
			</div>
			<div class="departamento-new-page-header-spacer" aria-hidden="true"></div>
		</header>

		{{ form_start(form, {
            action: path('app_departamento_new'),
            attr: {
                'data-turbo-frame': 'content',
                'class': 'departamento-new-page-form'
            }
        }) }}

		<div class="departamento-new-page-section-card">
			<div class="departamento-new-page-section-header">
				<i class="bi bi-building"></i>
				<span>Información básica</span>
			</div>
			<div class="departamento-new-page-section-body">
				<div class="departamento-new-page-group">
					{{ form_label(form.nombre, 'Nombre del departamento', {'label_attr': {'class': 'departamento-new-page-label'}}) }}
					<div class="departamento-new-page-input-wrapper">
						<i class="bi bi-building departamento-new-page-input-icon"></i>
						{{ form_widget(form.nombre, {'attr': {'class': 'departamento-new-page-input departamento-new-page-input--with-icon', 'placeholder': 'Ingresa el nombre del departamento'}}) }}
					</div>
					{{ form_errors(form.nombre) }}
				</div>
			</div>
		</div>

<div class="departamento-new-page-actions">
			<button type="submit" class="departamento-new-page-save-btn">
				<i class="bi bi-check-circle-fill"></i>
				<span>Guardar departamento</span>
			</button>
		</div>

		{{ form_end(form) }}

	</section>
</turbo-frame>
