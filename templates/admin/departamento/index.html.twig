<turbo-frame id="content">
	<section class="departamento-index-page-card" data-page="departamento-index">

		<h4 class="departamento-index-page-title">
			<i class="bi bi-buildings-fill"></i>
			Lista de departamentos
		</h4>

		<div class="departamento-index-page-toolbar">

			<div class="departamento-index-page-toolbar-left">
				<a href="{{ path('app_departamento_new') }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="departamento-index-page-add-btn">
					<i class="bi bi-building-add"></i>
					<span>Crear nuevo</span>
				</a>
			</div>

			<div class="departamento-index-page-toolbar-right">
				<div class="departamento-index-page-search">
					<i class="bi bi-search"></i>
					<input type="text"
						   id="departamento-search"
						   placeholder="Buscar departamento...">
				</div>
			</div>

		</div>

		<div class="departamento-index-page-table-wrapper">
			<table class="departamento-index-page-table">
				<thead>
					<tr>
						<th>Nombre</th>
						<th>Estado</th>
						<th>Acciones</th>
					</tr>
				</thead>

				<tbody>
					{% for departamento in departamentos %}
						<tr class="departamento-index-page-row">
							<td class="departamento-index-page-name">
								{{ departamento.nombre }}
							</td>

							<td class="text-center">
								<span class="departamento-index-page-badge {{ departamento.activo ? 'departamento-index-page-badge--active' : 'departamento-index-page-badge--inactive' }}">
									{{ departamento.activo ? 'Activo' : 'Inactivo' }}
								</span>
							</td>

							<td class="text-center">
								<div class="departamento-index-page-actions">
									<a href="{{ path('app_departamento_show', {'id': departamento.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="departamento-index-page-action-btn departamento-index-page-action-btn--view"
									   title="Ver departamento">
										<i class="bi bi-eye"></i>
									</a>

									<a href="{{ path('app_departamento_edit', {'id': departamento.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="departamento-index-page-action-btn departamento-index-page-action-btn--edit"
									   title="Editar departamento">
										<i class="bi bi-pencil-square"></i>
									</a>
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="3" class="departamento-index-page-empty">
								No se encontraron registros.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</section>
</turbo-frame>