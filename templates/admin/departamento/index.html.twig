<turbo-frame id="content">
    <section class="departamento-index">

        <!-- TOOLBAR -->
        <div class="departamento-index__toolbar">
            <h1 class="departamento-index__title">Lista de departamentos</h1>
        </div>

        <!-- ACCIONES DE TABLA -->
        <div class="departamento-index__table-actions">
            <a
                href="{{ path('app_departamento_new') }}"
                class="departamento-index__add-btn"
            >
                <i class="bi bi-building-add"></i>
                Crear nuevo
            </a>
        </div>

        <!-- TABLA -->
        <div class="departamento-index__table-wrapper">
            <table class="departamento-index__table">
                <thead>
                    <tr>
                        
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                        

                    </tr>
                </thead>

                <tbody>
                {% for departamento in departamentos %}
                    <tr>
                        
                        <td>{{ departamento.nombre }}</td>
                        <td>
                            <span class="departamento-index__badge {{ departamento.activo ? 'is-active' : 'is-inactive' }}">
                                {{ departamento.activo ? 'Activo' : 'Inactivo' }}
                            </span>
                        </td>

                        <td>
                            <div class="departamento-index__actions">
                                <a
                                    href="{{ path('app_departamento_show', {'id': departamento.id}) }}"
                                    class="departamento-index__action departamento-index__action--view"
                                >
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a
                                    href="{{ path('app_departamento_edit', {'id': departamento.id}) }}"
                                    class="departamento-index__action departamento-index__action--edit"
                                >
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="departamento-index__empty">
                            No se encontraron registros
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    </section>
</turbo-frame>
