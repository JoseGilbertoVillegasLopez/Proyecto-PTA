<turbo-frame id="content">
	<section class="proceso-estrategico-new-card">

		<header class="proceso-estrategico-new-header">

			<a href="{{ path('app_proceso_estrategico_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="proceso-estrategico-new-back-btn"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<h1 class="proceso-estrategico-new-title">
				Crear nuevo proceso estratégico
			</h1>

			<div class="proceso-estrategico-new-header-spacer" aria-hidden="true"></div>

		</header>

		{{ form_start(form, {
			action: path('app_proceso_estrategico_new'),
			attr: {
				'data-turbo-frame': 'content',
				'class': 'proceso-estrategico-new-form'
			}
		}) }}

			<div class="proceso-estrategico-new-group">
				{{ form_label(form.nombre, null, {'label_attr': {'class': 'proceso-estrategico-new-label'}}) }}
				{{ form_widget(form.nombre, {'attr': {'class': 'proceso-estrategico-new-input'}}) }}
				{{ form_errors(form.nombre) }}
			</div>

			<div class="proceso-estrategico-new-actions">
				<button type="submit" class="proceso-estrategico-new-submit-btn" title="Guardar">
					<i class="bi bi-check-lg"></i>
				</button>
			</div>

		{{ form_end(form) }}

	</section>
</turbo-frame>