<turbo-frame id="content">
	<section class="proceso-estrategico-show">

		<header class="proceso-estrategico-show__header">

			<a href="{{ path('app_proceso_estrategico_index') }}"
			   data-turbo-frame="content"
			   data-turbo-action="replace"
			   class="proceso-estrategico-show__icon-btn proceso-estrategico-show__icon-btn--back"
			   title="Volver">
				<i class="bi bi-arrow-left"></i>
			</a>

			<h1 class="proceso-estrategico-show__title">
				Información del proceso estratégico
			</h1>

			<div class="proceso-estrategico-show__header-actions">
				<a href="{{ path('app_proceso_estrategico_edit', {'id': proceso.id}) }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="proceso-estrategico-show__icon-btn proceso-estrategico-show__icon-btn--edit"
				   title="Editar">
					<i class="bi bi-pencil"></i>
				</a>
			</div>

		</header>

		<table class="proceso-estrategico-show__table">
			<tbody>
				<tr>
					<th>Nombre</th>
					<td>{{ proceso.nombre }}</td>
				</tr>
			</tbody>
		</table>

	</section>
</turbo-frame>