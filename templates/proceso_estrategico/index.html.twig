<turbo-frame id="content">
	<div class="card proceso-estrategico-index-card" data-page="proceso-estrategico-index">

		<h4 class="mb-3 proceso-estrategico-index-main-title">
			<i class="bi bi-diagram-3-fill"></i>
			Lista de procesos estratégicos
		</h4>

		<div class="proceso-estrategico-index-toolbar">

			<div class="proceso-estrategico-index-toolbar__left">
				<a href="{{ path('app_proceso_estrategico_new') }}"
				   data-turbo-frame="content"
				   data-turbo-action="advance"
				   class="proceso-estrategico-index-create-btn">
					<i class="bi bi-plus-circle-fill"></i>
					<span>Crear nuevo</span>
				</a>
			</div>

			<div class="proceso-estrategico-index-toolbar__right">
				<div class="proceso-estrategico-index-searchbox">
					<i class="bi bi-search"></i>
					<input type="text"
						   id="proceso-estrategico-search"
						   placeholder="Buscar proceso estratégico..."
						   autocomplete="off">
				</div>
			</div>
		</div>

		<div class="proceso-estrategico-index-table-wrapper">
			<table class="proceso-estrategico-index-table">
				<thead>
					<tr>
						<th>Nombre</th>
						<th class="text-center">Estado</th>
						<th class="text-center">Acciones</th>
					</tr>
				</thead>
				<tbody>
					{% for proceso in proceso_estrategicos %}
						<tr class="proceso-estrategico-index-row">
							<td class="proceso-estrategico-index-row-name">
								{{ proceso.nombre }}
							</td>

							<td class="text-center">
								<span class="proceso-estrategico-index-status-badge {{ proceso.activo ? 'proceso-estrategico-index-status-badge--active' : 'proceso-estrategico-index-status-badge--inactive' }}">
									{{ proceso.activo ? 'Activo' : 'Inactivo' }}
								</span>
							</td>

							<td class="text-center">
								<div class="proceso-estrategico-index-row-actions">
									<a href="{{ path('app_proceso_estrategico_show', {'id': proceso.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="proceso-estrategico-index-row-action-btn proceso-estrategico-index-row-action-btn--view"
									   title="Ver proceso estratégico">
										<i class="bi bi-eye"></i>
									</a>

									<a href="{{ path('app_proceso_estrategico_edit', {'id': proceso.id}) }}"
									   data-turbo-frame="content"
									   data-turbo-action="advance"
									   class="proceso-estrategico-index-row-action-btn proceso-estrategico-index-row-action-btn--edit"
									   title="Editar proceso estratégico">
										<i class="bi bi-pencil-square"></i>
									</a>
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="3" class="text-center text-muted proceso-estrategico-index-empty-row">
								No se encontraron procesos estratégicos.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>
</turbo-frame>