{% extends 'base.html.twig' %}

{% block title %}Dashboard
{% endblock %}

{% block body %}
	<script>
		document.addEventListener("turbo:render", function () {
if (typeof Sfjs !== "undefined") {
Sfjs.loadToolbar();
}
});
	</script>

	<div
		style="display: flex; height: 94.8vh; background: #1e242b;">

		<!-- ASIDE -->
		<aside
			class="pta-dashboard-aside">

			<!-- BLOQUE CENTRADO -->
			<div
				class="pta-dashboard-menu-wrapper">

				<!-- HEADER -->
				<div class="pta-dashboard-header">
					<i class="bi bi-speedometer2 pta-dashboard-icon"></i>
					<h2 class="pta-dashboard-title">Menú</h2>
				</div>

				<!-- MENU -->
				<ul
					class="pta-dashboard-menu">

					{# ============================
																																																																																																																			       SOLO ADMIN
																																																																																																																			       ============================ #}
					{% if is_granted('ROLE_ADMIN') %}
						<li class="pta-dashboard-menu-item">
							<a href="{{ path('app_admin_dashboard', { section: 'personal' }) }}" class="pta-dashboard-link" data-turbo-action="advance">
								Personal
							</a>
						</li>

						<li class="pta-dashboard-menu-item">
							<a href="{{ path('app_admin_dashboard', { section: 'departamentos' }) }}" class="pta-dashboard-link" data-turbo-action="advance">
								Departamentos
							</a>
						</li>

						<li class="pta-dashboard-menu-item">
							<a href="{{ path('app_admin_dashboard', { section: 'puestos' }) }}" class="pta-dashboard-link" data-turbo-action="advance">
								Puestos
							</a>
						</li>
					{% endif %}

					{# ============================
																																																																																																																			       TODOS LOS USUARIOS
																																																																																																																			       ============================ #}
					<li class="pta-dashboard-menu-item">
						<a href="{{ path('app_admin_dashboard', { section: 'pta' }) }}" class="pta-dashboard-link" data-turbo-action="advance">
							PTA
						</a>
					</li>

					<li class="pta-dashboard-menu-item">
						<a href="{{ path('app_admin_dashboard', { section: 'monitoreo' }) }}" class="pta-dashboard-link" data-turbo-action="advance">
							Monitoreo PTA
						</a>
					</li>

				</ul>

			</div>

			<!-- LOGOUT -->
			<a href="{{ path('app_logout') }}" class="pta-dashboard-logout" title="Cerrar sesión">
				<i class="bi bi-door-open-fill"></i>
				Salir
			</a>

		</aside>

		<!-- CONTENIDO -->
		<main
			style="flex: 1; padding: 30px; overflow-y: auto;">
			{# ============================
															   FIX GLOBAL SECTION
															   ============================ #}
			{% set section = section is defined ? section : null %}

			{% set srcMap = {
  'personal': path('app_personal_index'),
  'departamentos': path('app_departamento_index'),
  'puestos': path('app_puesto_index'),
  'pta': path('app_encabezado_index'),
  'monitoreo': path('pta_monitoreo_index')
} %}

			{# ============================
																																																															   SECCIÓN INICIAL POR ROL
																																																															   ============================ #}
			{% if is_granted('ROLE_ADMIN') %}
				{% set defaultSection = 'personal' %}
			{% else %}
				{% set defaultSection = 'pta' %}
			{% endif %}

			<turbo-frame id="content" src="{{ content_url ?? srcMap[section] ?? srcMap[defaultSection] }}"></turbo-frame>


		</main>
	{% endblock %}
