<turbo-frame id="content">
	<section class="pta-resp-edit-page">

		<div class="pta-resp-edit-container">
			<div class="pta-resp-edit-shell">
				<div class="pta-resp-edit-topbar">
					<a href="{{ volver_path|default(path('app_encabezado_show', { id: encabezado.id })) }}"
						data-turbo-frame="content"
						data-turbo-action="replace"
						class="pta-resp-edit-back-btn">
						<i class="bi bi-arrow-left"></i>
						<span>Volver</span>
					</a>
				</div>

				<div class="pta-resp-project-details">
					<div class="pta-resp-project-detail pta-resp-project-detail--name">
						<span class="pta-resp-project-detail-label">Nombre del Proyecto</span>
						<span class="pta-resp-project-detail-value">{{ encabezado.nombre }}</span>
					</div>

					<div class="pta-resp-project-detail pta-resp-project-detail--number">
						<span class="pta-resp-project-detail-label">Numero de Proyecto</span>
						<span class="pta-resp-project-detail-value">{{ encabezado.id }}</span>
					</div>

					<div class="pta-resp-project-detail pta-resp-project-detail--objective">
						<span class="pta-resp-project-detail-label">Objetivo</span>
						<span class="pta-resp-project-detail-value">{{ encabezado.objetivo }}</span>
					</div>
				</div>

				<form method="post"
					action="{{ path('app_encabezado_responsables_edit', { id: encabezado.id }) }}"
					data-turbo-frame="content"
					id="responsables-form"
					class="pta-resp-edit-form">

				<div class="pta-resp-card">
					<h4 class="pta-resp-card-title">
						<i class="bi bi-people-fill"></i>
						Responsables del Proyecto
					</h4>

					<div class="pta-resp-fields">
						<div class="pta-resp-field">
							<label for="responsable-search">Responsable</label>
							<div class="pta-resp-input-wrap">
								<input type="hidden" name="responsable_id" value="{{ encabezado.responsable.id ?? '' }}">
								<input id="responsable-search"
									type="text"
									class="responsable-search"
									autocomplete="off"
									value="{{ encabezado.responsable ?? '' }}">
								<div class="responsable-results search-results"></div>
							</div>
						</div>

						<div class="pta-resp-field">
							<label for="supervisor-search">Supervisor</label>
							<div class="pta-resp-input-wrap">
								<input type="hidden" name="supervisor_id" value="{{ encabezado.responsables.supervisor.id ?? '' }}">
								<input id="supervisor-search"
									type="text"
									class="supervisor-search"
									autocomplete="off"
									value="{{ encabezado.responsables.supervisor ?? '' }}">
								<div class="supervisor-results search-results"></div>
							</div>
						</div>

						<div class="pta-resp-field">
							<label for="aval-search">Aval</label>
							<div class="pta-resp-input-wrap">
								<input type="hidden" name="aval_id" value="{{ encabezado.responsables.aval.id ?? '' }}">
								<input id="aval-search"
									type="text"
									class="aval-search"
									autocomplete="off"
									value="{{ encabezado.responsables.aval ?? '' }}">
								<div class="aval-results search-results"></div>
							</div>
						</div>
					</div>
				</div>

				<input type="hidden" name="_token" value="{{ csrf_token('responsables_' ~ encabezado.id) }}">

				<div class="pta-resp-actions">
					<button type="button" class="pta-resp-save-btn js-confirmar-responsables" id="btn-confirmar">
						<i class="bi bi-floppy2-fill"></i>
						<span>Guardar cambios</span>
					</button>
				</div>
			</form>
			</div>
		</div>

		<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered">
				<div class="modal-content pta-resp-modal">
					<div class="modal-header">
						<h5 class="modal-title">
							<i class="bi bi-shield-check"></i>
							Confirmar cambios
						</h5>
						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
					</div>
					<div class="modal-body">
						<p class="pta-resp-modal-note">Revisa las asignaciones antes de guardar.</p>
						<ul id="lista-cambios" class="pta-resp-change-list list-group"></ul>
					</div>
					<div class="modal-footer">
						<button type="button" class="pta-resp-cancel-btn" data-bs-dismiss="modal">Cancelar</button>
						<button type="button" class="pta-resp-save-btn" id="btn-guardar-final">Confirmar</button>
					</div>
				</div>
			</div>
		</div>

	</section>
</turbo-frame>
