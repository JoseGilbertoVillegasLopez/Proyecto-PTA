<turbo-frame id="content">

	<div class="card pta-card">

		<h4 class="pta-title mb-3">
			<i class="bi bi-list-ul"></i>
			Proyectos PTA
		</h4>
		<div
			class="pta-toolbar">

			{# IZQUIERDA — BOTÓN AGREGAR #}
			<div class="pta-toolbar-left">
				<div class="pta-toolbar-left">
					<a href="{{ path('app_encabezado_new') }}" data-turbo-frame="content" data-turbo-action="advance" class="pta-add-btn">
						<i class="bi bi-plus-circle"></i>
						<span>Agregar</span>
					</a>
				</div>

			</div>

			{# DERECHA — FILTRO #}
			<div class="pta-toolbar-right">
				<form method="get" action="{{ path('app_encabezado_index') }}" data-turbo-frame="content" class="pta-filter-form">

					<label class="form-label mb-0">AÑO DE EJEUCÍON</label>
					<select name="anio">
						{% for anio in aniosFiltro %}
							<option value="{{ anio }}" {{ anio == anioSeleccionado ? 'selected' }}>
								{{ anio }}
							</option>
						{% endfor %}
					</select>
					{% if access.filters.departamento and departamentosFiltro is not empty %}
						<select name="departamento">
							<option value="">Departamento</option>
							{% for id, nombre in departamentosFiltro %}
								<option value="{{ id }}" {{ filtrosActivos.departamento == id ? 'selected' }}>
									{{ nombre }}
								</option>
							{% endfor %}
						</select>
					{% endif %}

					{% if access.filters.puesto and puestosFiltro is not empty %}
						<select name="puesto">
							<option value="">Puesto</option>
							{% for id, nombre in puestosFiltro %}
								<option value="{{ id }}" {{ filtrosActivos.puesto == id ? 'selected' }}>
									{{ nombre }}
								</option>
							{% endfor %}
						</select>
					{% endif %}

					<button type="submit" class="btn btn-primary">
						<i class="bi bi-funnel"></i>
					</button>
				</form>
			</div>
		</div>


		<table class="pta-monitoreo-table pta-index-table">
			<thead>
				<tr>
					<th>#</th>
					<th>Nombre del proyecto</th>
					<th>Objetivo</th>
					<th class="text-center">Creado</th>
					<th class="text-center">Periodo</th>
					<th class="text-center">Acciones</th>
				</tr>
			</thead>
			<tbody>

				{% for encabezado in encabezados %}
					<tr>

						{# Número de proyecto #}
						<td>
							<strong>{{ encabezado.id }}</strong>
						</td>

						{# Nombre #}
						<td>
							{{ encabezado.nombre }}
						</td>

						{# Objetivo #}
						<td class="text-truncate" style="max-width: 400px;">
							{{ encabezado.objetivo }}
						</td>

						{# CREADO #}
						<td class="text-center">
							{{ encabezado.fechaCreacion|date('d/m/Y') }}
						</td>

						{# PERIODO / AÑO DE EJECUCIÓN #}
						<td class="text-center">
							<span class="pta-badge pta-badge-periodo">
								{{ encabezado.anioEjecucion }}
							</span>
						</td>


						<td class="text-center">
							<div class="pta-actions">

								<a href="{{ path('app_encabezado_show', { id: encabezado.id, anio: anioSeleccionado, departamento: filtrosActivos.departamento, puesto: filtrosActivos.puesto, from: 'index' }) }}" data-turbo-frame="content" data-turbo-action="advance" class="pta-action-btn pta-action-view" title="Ver PTA">
									<i class="bi bi-eye"></i>
								</a>

								{% if encabezado.responsable and encabezado.responsable.user == app.user %}
									<a href="{{ path('app_encabezado_edit', { id: encabezado.id, anio: anioSeleccionado, departamento: filtrosActivos.departamento, puesto: filtrosActivos.puesto }) }}" data-turbo-frame="content" data-turbo-action="advance" class="pta-action-btn pta-action-edit" title="Editar PTA">
										<i class="bi bi-pencil-square"></i>
									</a>
								{% endif %}

								<a href="{{ path('app_reporte_pta_index', { id: encabezado.id }) }}" data-turbo-frame="content" data-turbo-action="advance" class="pta-action-btn pta-action-report" title="Ver reportes trimestrales">
									<i class="bi bi-file-earmark-bar-graph"></i>
								</a>

							</div>
						</td>


					</tr>
				{% else %}
					<tr>
						<td colspan="4" class="text-center text-muted">
							No hay proyectos registrados.
						</td>
					</tr>
				{% endfor %}

			</tbody>
		</table>

	</div>

</turbo-frame>
