{# ============================================================
   TURBO FRAME PRINCIPAL
   ------------------------------------------------------------
   - Este frame es el contenedor donde Turbo inyecta la vista
   - El JS del módulo PTA se engancha específicamente a este ID
   - Si el ID cambia, el JS NO se ejecutará
   ============================================================ #}
<div class="pta-back-wrapper">
	<a href="{{ volver_path }}" {% if usar_turbo %} data-turbo-frame="content" data-turbo-action="replace" {% endif %} class="pta-back-btn">
		<i class="bi bi-arrow-left"></i>
		<span>Volver</span>
	</a>
</div>

{# Título principal de la vista #}
<h1 class="mb-4">Crear nuevo PTA</h1>

{{ form_start(form, {
	'action': path('app_encabezado_new'),
	'attr': {
		'data-turbo': 'content',
		'data-pta-form': 'pta-new'
	}
}) }}

{# ============================================================
   1. INFORMACIÓN DEL PROYECTO
   ============================================================ #}
<div class="card pta-card pta-info-card mb-4">

	<h4 class="pta-title">
		<i class="bi bi-file-earmark-text"></i>
		1. Información del Proyecto
	</h4>

	<div class="pta-info-grid">

		{# COLUMNA IZQUIERDA — NOMBRE + OBJETIVO #}
		<div class="pta-info-col-main">

			<div class="pta-field-group">
				<label class="pta-field-label">
					<i class="bi bi-pencil-square"></i>
					Nombre del Proyecto
				</label>
				{{ form_widget(form.nombre, {
					attr: { class: 'pta-input pta-textarea-nombre fixed-textarea', rows: 2, placeholder: 'Nombre del proyecto...' }
				}) }}
				{{ form_errors(form.nombre) }}
			</div>

			<div class="pta-field-group mt-3">
				<label class="pta-field-label">
					<i class="bi bi-bullseye"></i>
					Objetivo del Proyecto
				</label>
				{{ form_widget(form.objetivo, {
					attr: { class: 'pta-input pta-textarea-objetivo fixed-textarea', rows: 3, placeholder: 'Describe el objetivo general del proyecto...' }
				}) }}
				{{ form_errors(form.objetivo) }}
			</div>

		</div>

		{# COLUMNA DERECHA — AÑO DE EJECUCIÓN #}
		<div class="pta-info-col-side">

			<div class="pta-anio-card">
				<div class="pta-anio-icon">
					<i class="bi bi-calendar-check"></i>
				</div>
				<label class="pta-field-label mb-2">Año de Ejecución</label>
				{{ form_widget(form.anioEjecucion, {
					attr: { class: 'pta-input pta-anio-select' }
				}) }}
				{{ form_errors(form.anioEjecucion) }}
				<p class="pta-anio-hint">
					Año en que se ejecutará y evaluará este PTA.
				</p>
			</div>

		</div>

	</div>
</div>



{# ============================================================
   3. INDICADORES
   Cada indicador se construye como card individual por JS
   ============================================================ #}
<div class="card pta-card mb-4">

	<h4 class="pta-title">
		<i class="bi bi-graph-up"></i>
		3. Indicadores
	</h4>

	{# Contenedor vacío — JS inyecta aquí cada indicator-card #}
	<div
		data-collection-holder="indicadores"
		data-prototype="{{ form_widget(form.indicadores.vars.prototype)|e('html_attr') }}"
		class="indicadores-container">
	</div>

	<div class="text-center my-3">
		<button type="button" class="pta-add-btn" id="add-indicador">
			<i class="bi bi-plus-lg"></i>
			Agregar Indicador
		</button>
	</div>

</div>

{# ============================================================
   4. ACCIONES DEL PROYECTO
   Cada acción se construye como card individual por JS
   ============================================================ #}
<div class="card pta-card mb-4">

	<h4 class="pta-title">
		<i class="bi bi-list-task"></i>
		4. Acciones del Proyecto
	</h4>

	{# Contenedor vacío — JS inyecta aquí cada accion-card #}
	<div
		data-collection-holder="acciones"
		data-prototype="{{ form_widget(form.acciones.vars.prototype)|e('html_attr') }}"
		class="acciones-container">
	</div>

	<div class="text-center my-3">
		<button type="button" class="pta-add-btn" id="add-accion">
			<i class="bi bi-plus-lg"></i>
			Agregar Acción
		</button>
	</div>

</div>

{# ============================================================
   2. RESPONSABLES DEL PROYECTO
   ============================================================ #}
<div class="card pta-card mb-4">

	<h4 class="pta-title">
		<i class="bi bi-people-fill"></i>
		2. Responsables del Proyecto
	</h4>

	<div class="resp-grid">

		{# SUPERVISOR #}
		<div class="resp-card">
			<div class="resp-icon-wrap">
				<i class="bi bi-person-badge"></i>
			</div>
			<div class="resp-role">Supervisor del Proyecto</div>
			<div class="resp-search-wrap position-relative">
				<i class="bi bi-search resp-search-icon"></i>
				{{ form_widget(form.responsables.supervisor_search, {
					attr: {
						class: 'pta-input resp-input supervisor-search',
						placeholder: 'Buscar por nombre...'
					}
				}) }}
				{{ form_widget(form.responsables.supervisor) }}
				<div class="search-results supervisor-results"></div>
			</div>
		</div>

		{# AVAL #}
		<div class="resp-card">
			<div class="resp-icon-wrap">
				<i class="bi bi-person-check"></i>
			</div>
			<div class="resp-role">Aval del Proyecto</div>
			<div class="resp-search-wrap position-relative">
				<i class="bi bi-search resp-search-icon"></i>
				{{ form_widget(form.responsables.aval_search, {
					attr: {
						class: 'pta-input resp-input aval-search',
						placeholder: 'Buscar por nombre...'
					}
				}) }}
				{{ form_widget(form.responsables.aval) }}
				<div class="search-results aval-results"></div>
			</div>
		</div>

	</div>
</div>

	{# ============================================================
														            TOKEN CSRF
														            ------------------------------------------------------------
														            - Se renderiza manualmente
														            - Evita problemas con manipulación dinámica del DOM
														            ============================================================ #}
	{{ form_row(form._token) }}

	{# ============================================================BOTÓN FINAL DE SUBMIT============================================================ #}
	<div class="text-center mt-4 mb-3">
		<button type="submit" class="pta-save-btn">
			<i class="bi bi-floppy2-fill"></i>
			Guardar PTA
		</button>
	</div>

	{# ============================================================
	   MODAL — MODO DE CAPTURA MENSUAL
	   ------------------------------------------------------------
	   Se abre automáticamente cuando el usuario activa el toggle
	   "%" en un indicador. Pregunta si capturará el avance
	   mensual como valor absoluto o como porcentaje (0-100).
	   Solo aplica cuando esPorcentaje = true.
	   ============================================================ #}
	<div class="modal fade" id="modalCapturaPct" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content pta-modal">

				<div class="modal-header pta-modal__header">
					<h5 class="modal-title">
						<i class="bi bi-pencil-square"></i>
						¿Cómo registrarás el avance mensual?
					</h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
				</div>

				<div class="modal-body pta-modal__body">

					<p class="pta-modal__info">
						La meta del indicador es un <strong>porcentaje</strong>.
						Define en qué unidad capturarás tu avance cada mes:
					</p>

					<div class="captura-opciones">

						<button type="button" id="modalCapturaBtnAbs" class="captura-opcion active">
							<div class="captura-opcion-icon">
								<i class="bi bi-123"></i>
							</div>
							<div class="captura-opcion-texto">
								<strong>Valor absoluto</strong>
								<span>Registra números en la misma unidad que el valor base: alumnos, pesos, proyectos, etc.</span>
								<em>Ejemplo: base=700 alumnos, meta=30% de aumento → capturas 750, 800…</em>
							</div>
						</button>

						<button type="button" id="modalCapturaBtnPct" class="captura-opcion">
							<div class="captura-opcion-icon">
								<i class="bi bi-percent"></i>
							</div>
							<div class="captura-opcion-texto">
								<strong>Porcentaje (0 – 100%)</strong>
								<span>El indicador se mide en % directamente: eficiencia terminal, satisfacción, etc.</span>
								<em>Ejemplo: base=60%, meta=85% → capturas 70%, 78%, 85%…</em>
							</div>
						</button>

					</div>

				</div>

				<div class="modal-footer pta-modal__footer">
					<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
						Cancelar
					</button>
					{# Inicia deshabilitado — JS lo habilita cuando el usuario elige una opción #}
					<button type="button" class="btn pta-btn-primary" id="modalCapturaConfirm" disabled>
						<i class="bi bi-check-lg"></i>
						Confirmar
					</button>
				</div>

			</div>
		</div>
	</div>

	{# ============================================================MODAL DE ERRORES- Usado por el JS para mostrar validaciones- El contenido se llena dinámicamente============================================================ #}
	<div class="modal fade" id="erroresModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-lg modal-dialog-centered">
			<div class="modal-content bg-dark text-light border-warning">

				<div class="modal-header">
					<h5 class="modal-title text-warning">
						<i class="bi bi-exclamation-triangle"></i>
						Errores en el formulario
					</h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
				</div>

				<div class="modal-body">
					<p class="mb-2">
						Se encontraron los siguientes problemas. Corrígelos antes de continuar:
					</p>

					<ul
						id="errores-lista" class="list-group list-group-flush">{# Los errores se insertan vía JS #}
					</ul>
				</div>

				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
						Entendido
					</button>
				</div>
			</div>
		</div>
	</div>

	{# Fin del formulario (NO render_rest para evitar campos no deseados) #}
	{{ form_end(form, { render_rest: false }) }}
