{# ============================================================
   PTA — GRÁFICAS
   ------------------------------------------------------------
   Vista de visualización gráfica del PTA.
   - Renderiza una gráfica por cada indicador
   - Muestra meta, tendencia y porcentaje de avance
   - Desglosa el aporte de cada acción
   ------------------------------------------------------------
   IMPORTANTE:
   - Twig SOLO renderiza estructura y data-attributes
   - Los cálculos ya vienen procesados desde el controlador
   ============================================================ #}

<section
	class="pta-module" data-pta-view="graficas">

	{# =========================================================
						       HEADER SUPERIOR
						       ========================================================= #}
	<header class="pta-module__header">

		<div class="pta-module__header-left">
			<a href="{{ path('app_encabezado_show', { id: encabezado.id, anio: filtros.anio, departamento: filtros.departamento, puesto: filtros.puesto }) }}" {% if app.user and 'ROLE_ADMIN' in app.user.roles %} data-turbo-frame="content" data-turbo-action="replace" {% endif %} class="pta-back-btn">
				<i class="bi bi-arrow-left"></i>
				<span>Volver</span>
			</a>
		</div>

		<h1 class="pta-module__title">
			📊 Gráficas del PTA
		</h1>

	</header>

	{# =========================================================
						       CONTENIDO PRINCIPAL
						       ========================================================= #}
	<div class="pta-module__content">

		{% for grafica in graficas %}

			{# =================================================
																		               CARD POR INDICADOR
																		               ================================================= #}
			<div
				class="pta-card pta-grafica-card mb-4">


				{# ================= HEADER INDICADOR ================= #}
				<div class="pta-card__header pta-indicador-header">

					<div class="pta-indicador-main">
						<h3 class="pta-indicador-title">
							{{ grafica.indicador }}
						</h3>
					</div>

					<div class="pta-indicador-stats">
						<div class="pta-stat">
							<span class="pta-stat-label">Valor base</span>
							<span class="pta-stat-value">
								{{ grafica.valor_base }}
							</span>
						</div>


						<div class="pta-stat">
							<span class="pta-stat-label">Meta</span>
							<span class="pta-stat-value">
								{{ grafica.meta }}
							</span>
						</div>

						<div class="pta-stat">
							<span class="pta-stat-label">Tendencia</span>
							{% if grafica.tendencia == 'POSITIVA' %}
								<span class="pta-badge pta-badge-positiva">
									Positiva
								</span>
							{% else %}
								<span class="pta-badge pta-badge-negativa">
									Negativa
								</span>
							{% endif %}
						</div>

						<div class="pta-stat">
							<span class="pta-stat-label">Avance</span>
							<span class="pta-stat-value">
								{{ grafica.porcentaje }}%
							</span>
						</div>

					</div>
				</div>

				{# ================= BODY GRÁFICA ================= #}
				<div class="pta-card__body pta-chart-wrap">
					<canvas class="pta-chart"
						data-indicador="{{ grafica.indicador }}"
						data-meta="{{ grafica.meta_grafica }}"
						data-tendencia="{{ grafica.tendencia }}"
						data-serie='{{ grafica.serie|json_encode|raw }}'
						data-captura-pct="{{ grafica.captura_porcentaje is defined and grafica.captura_porcentaje ? '1' : '0' }}"
						data-valor-base="{{ grafica.valor_base }}">
					</canvas>
				</div>

				{# Sección de desglose por acciones eliminada:
				   el avance ya no se registra por acción sino por indicador #}

			</div>

		{% else %}

			<div class="text-center text-muted">
				No hay indicadores para mostrar.
			</div>

		{% endfor %}

	</div>

</section>
