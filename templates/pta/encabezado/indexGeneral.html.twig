{% extends 'base.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/pta/index-general.css') }}">
{% endblock %}

{% block body %}

	<div class="pta-general-layout">

		<main class="pta-general-main">

			<div class="pta-card">

				<h4 class="pta-title mb-3">
					<i class="bi bi-list-ul"></i>
					Proyectos PTA
				</h4>

				<div
					class="pta-toolbar">

					<!-- IZQUIERDA -->
					<div class="pta-toolbar-left">
						<a href="{{ path('app_encabezado_new') }}" class="pta-add-btn">
							<i class="bi bi-plus-circle"></i>
							<span>Agregar</span>
						</a>
					</div>

					<!-- DERECHA -->
					<div class="pta-toolbar-right">
						<form method="get" action="{{ path('app_encabezado_index') }}" class="pta-filter-form">

							<label class="form-label mb-0">
								Año de ejecución
							</label>

							<select name="anio" class="form-select">
								{% set anioActual = "now"|date("Y") %}
								{% set anioSeleccionado = anioSeleccionado ?? anioActual %}
								<option value="{{ anioActual }}" {{ anioActual == anioSeleccionado ? 'selected' }}>
									{{ anioActual }}
								</option>
								<option value="{{ anioActual + 1 }}" {{ (anioActual + 1) == anioSeleccionado ? 'selected' }}>
									{{ anioActual + 1 }}
								</option>
							</select>

							{% if access.filters.departamento %}
								<select name="departamento" class="form-select">
									<option value="">Departamento</option>
									{% for id, nombre in departamentosFiltro %}
										<option value="{{ id }}" {{ filtrosActivos.departamento == id ? 'selected' }}>
											{{ nombre }}
										</option>
									{% endfor %}
								</select>
							{% endif %}

							{% if access.filters.puesto %}
								<select name="puesto" class="form-select">
									<option value="">Puesto</option>
									{% for id, nombre in puestosFiltro %}
										<option value="{{ id }}" {{ filtrosActivos.puesto == id ? 'selected' }}>
											{{ nombre }}
										</option>
									{% endfor %}
								</select>
							{% endif %}

							<button type="submit" class="btn btn-primary">
								<i class="bi bi-funnel"></i>
							</button>
						</form>
					</div>
				</div>

				<table class="table table-dark table-hover align-middle">
					<thead>
						<tr>
							<th>#</th>
							<th>Nombre del proyecto</th>
							<th>Objetivo</th>
							<th class="text-center">Creado</th>
							<th class="text-center">Periodo</th>
							<th class="text-center">Acciones</th>
						</tr>
					</thead>
					<tbody>
						{% for encabezado in encabezados %}
							<tr>
								<td>
									<strong>{{ encabezado.id }}</strong>
								</td>
								<td>{{ encabezado.nombre }}</td>
								<td class="text-truncate" style="max-width: 400px;">
									{{ encabezado.objetivo }}
								</td>
								<td class="text-center">
									{{ encabezado.fechaCreacion|date('d/m/Y') }}
								</td>
								<td class="text-center">
									<span class="pta-badge pta-badge-periodo">
										{{ encabezado.anioEjecucion }}
									</span>
								</td>
								<td class="text-center">
									<div class="pta-actions">
										<a href="{{ path('app_encabezado_show', { id: encabezado.id }) }}" class="pta-action-btn pta-action-view">
											<i class="bi bi-eye"></i>
										</a>
										<a href="{{ path('app_encabezado_edit', { id: encabezado.id }) }}" class="pta-action-btn pta-action-edit">
											<i class="bi bi-pencil-square"></i>
										</a>
									</div>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="6" class="text-center text-muted">
									No hay proyectos registrados.
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>

			</div>

		</main>

	</div>

{% endblock %}
