<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">

		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>

		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22>
																																							          <text y=%221.2em%22 font-size=%2296%22>⚫️</text>
																																							          <text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text>
																																							          </svg>">

		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/dashboard/dashboard.css') }}">
			<link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
			<link rel="stylesheet" href="{{ asset('css/pta/new.css') }}">
			<link rel="stylesheet" href="{{ asset('css/pta/edit.css') }}">
			<link rel="stylesheet" href="{{ asset('css/pta/show.css') }}">
			<link rel="stylesheet" href="{{ asset('css/pta/index.css') }}">
			<link rel="stylesheet" href="{{ asset('css/pta/monitoreo.css') }}">
			<link rel="stylesheet" href="{{ asset('css/historial/historial.css') }}">
			<link rel="stylesheet" href="{{ asset('css/pta/grafica.css') }}">
			<link rel="stylesheet" href="{{ asset('css/personal/personal.css') }}">
			<link rel="stylesheet" href="{{ asset('css/departamento/departamento.css') }}">
			<link rel="stylesheet" href="{{ asset('css/puesto/puesto.css') }}">
			<link rel="stylesheet" href="{{ asset('libs/bootstrap-icons/bootstrap-icons.css') }}">
		{% endblock %}

		{% block javascripts %}
			<script src="{{ asset('js/bootstrap.bundle.min.js') }}"></script>
			<script src="{{ asset('js/pta/new.js') }}" defer></script>
			<script src="{{ asset('js/pta/graficas.js') }}" defer></script>
			<script src="{{ asset('js/pta/filtro-personal-index.js') }}" defer></script>
			<script src="{{ asset('js/pta/pta-responsables.js') }}" defer></script>
			<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
		{% endblock %}

		{% block importmap %}
			{{ importmap('app') }}
		{% endblock %}
	</head>

	<body>
		{% block body %}{% endblock %}

		<style>
			body {
				background: #1e242b;
			}
			h1 {
				color: #aaa;
				text-align: center;
			}
		</style>
	</body>
</html>
