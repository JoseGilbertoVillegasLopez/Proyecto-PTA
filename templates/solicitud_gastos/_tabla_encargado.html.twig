{% set sg_estado_iconos = {
	'pendiente': 'bi-clock-fill',
	'en_revision': 'bi-eye-fill',
	'aceptada': 'bi-check-circle-fill',
	'rechazada': 'bi-x-circle-fill',
	'resuelto': 'bi-patch-check-fill'
} %}
{% set sg_estado_labels = {
	'pendiente': 'Pendiente',
	'en_revision': 'En revisión',
	'aceptada': 'Aceptada',
	'rechazada': 'Rechazada',
	'resuelto': 'Resuelto'
} %}
{% for solicitud in solicitudes %}
	<tr>
		<td class="sg-index__col-id" data-label="#">{{ solicitud.id }}</td>
		<td class="sg-index__col-solicitante sg-index__col-nombre" data-label="Solicitante">{{ solicitud.solicitante }}</td>
		<td class="sg-index__col-depto" data-label="Departamento">{{ solicitud.solicitante.departamento.nombre }}</td>
		<td class="sg-index__col-tipo" data-label="Tipo">{{ solicitud.tipoSolicitud.nombre }}</td>
		<td class="sg-index__col-concepto" data-label="Por concepto de">{{ solicitud.porConceptoDe }}</td>
		<td class="sg-index__col-fecha" data-label="Para cuándo">{{ solicitud.fechaNecesita|date('d/m/Y') }}</td>
		<td class="sg-index__col-total" data-label="Total">$ {{ solicitud.cantidadTotal|number_format(2, '.', ',') }}</td>
		<td class="sg-index__col-estado" data-label="Estado">
			<span class="sg-badge sg-badge--{{ solicitud.estado }}">
				<i class="bi {{ sg_estado_iconos[solicitud.estado] }}"></i> {{ sg_estado_labels[solicitud.estado] }}
			</span>
		</td>
		<td class="sg-index__col-avance" data-label="Avance">{{ solicitud.contarRevisionesResueltas }}/3</td>
		<td class="sg-index__col-acciones" data-label="Acciones">
			<a href="{{ path('app_solicitud_gastos_show', { id: solicitud.id }) }}"
			   class="sg-index__action-btn sg-index__action-btn--ver"
			   data-turbo-frame="content"
			   data-turbo-action="advance"
			   title="Ver solicitud">
				<i class="bi bi-eye"></i>
			</a>
		</td>
	</tr>
{% else %}
	<tr>
		<td colspan="10" class="sg-index__empty">
			<i class="bi bi-inbox"></i>
			<span>No hay solicitudes con los filtros actuales.</span>
		</td>
	</tr>
{% endfor %}
